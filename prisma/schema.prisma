// =============================================================
// 33. depot_prices — ราคาคลังต่อวัน (PTT/Shell/Dao Evo) — FUELOS §2.4 / §12
// หัวหน้ากรอกทุกเช้า; เซลล์เห็นพร้อมกัน
// =============================================================
model DepotPrice {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  date        DateTime  @db.Date
  depotName   String    @map("depot_name") // PTT | Shell | DaoEvo
  productType String    @map("product_type") // B7 | B10 | 91 | 95
  depotPrice  Decimal   @map("depot_price") @db.Decimal(10, 4) // ฿/L (4dp)
  validUntil  String    @map("valid_until") // HH:mm e.g. "17:00"
  enteredById String?   @map("entered_by_id") @db.Uuid
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  enteredBy User?        @relation("DepotPriceEntered", fields: [enteredById], references: [id], onDelete: SetNull)

  @@unique([orgId, date, depotName, productType])
  @@index([orgId, date])
  @@map("depot_prices")
  @@schema("public")
}

// =============================================================
// 34. zone_margins — Zone × product margin (admin config) — FUELOS §2.4
// =============================================================
model ZoneMargin {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  zoneName    String   @map("zone_name") // KKN, Udon, Korat, ...
  productType String   @map("product_type") // B7 | B10 | 91 | 95
  baseMargin  Decimal  @map("base_margin") @db.Decimal(10, 4) // ฿/L
  minMargin   Decimal  @map("min_margin") @db.Decimal(10, 4) // ฿/L
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@unique([orgId, zoneName, productType])
  @@index([orgId, isActive])
  @@map("zone_margins")
  @@schema("public")
}

// =============================================================
// 35. contacts — คนที่คุยด้วย (Multi-Entity layer 1) — FUELOS §14.1 / §14.6
// Group credit limit aggregates across entities under this contact
// =============================================================
model Contact {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  name             String
  nickname         String?
  phone            String?
  phone2           String?
  lineUserId       String?  @map("line_user_id")
  assignedSalesId  String?  @map("assigned_sales_id") @db.Uuid
  creditGroupLimit Decimal? @map("credit_group_limit") @db.Decimal(15, 2)
  creditGroupUsed  Decimal  @default(0) @map("credit_group_used") @db.Decimal(15, 2)
  notes            String?
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org           Organization      @relation(fields: [orgId], references: [id], onDelete: Restrict)
  assignedSales User?             @relation("ContactSales", fields: [assignedSalesId], references: [id], onDelete: SetNull)
  entities      CustomerEntity[]
  quotes        CustomerQuote[]
  priceAlerts   PriceAlertLog[]
  lineResponses LineResponseLog[]

  @@unique([orgId, lineUserId])
  @@index([orgId, isActive])
  @@index([assignedSalesId])
  @@map("contacts")
  @@schema("public")
}

// =============================================================
// 36. customer_entities — นิติบุคคล/บุคคลธรรมดา (Multi-Entity layer 2)
// Spec: FUELOS §14.1 / §14.6 — invoice ออกในนาม Entity, credit ราย Entity
// =============================================================
model CustomerEntity {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  contactId     String   @map("contact_id") @db.Uuid
  entityType    String   @map("entity_type") // company | partnership | individual
  legalName     String   @map("legal_name")
  taxId         String?  @map("tax_id")
  address       String?
  creditLimit   Decimal? @map("credit_limit") @db.Decimal(15, 2)
  creditUsed    Decimal  @default(0) @map("credit_used") @db.Decimal(15, 2)
  paymentTerms  Int?     @map("payment_terms") // days; null = COD
  paymentMethod String?  @map("payment_method") // transfer | cash | cheque | mixed
  docStatus     String   @default("incomplete") @map("doc_status") // complete | incomplete | expired
  creditScore   Int?     @map("credit_score") // 0-100, AI-computed (Sprint 6.4+)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org             Organization       @relation(fields: [orgId], references: [id], onDelete: Restrict)
  contact         Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  locations       DeliveryLocation[]
  fuelOrders      FuelOrder[]
  payments        Payment[]
  creditDocuments CreditDocument[]
  chequeTrackings ChequeTracking[]

  @@index([orgId, isActive])
  @@index([contactId])
  @@map("customer_entities")
  @@schema("public")
}

// =============================================================
// 37. delivery_locations — จุดส่งน้ำมัน (Multi-Entity layer 3) — FUELOS §14.1
// =============================================================
model DeliveryLocation {
  id             String   @id @default(uuid()) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  entityId       String   @map("entity_id") @db.Uuid
  name           String
  address        String?
  lat            Decimal? @db.Decimal(10, 7)
  lng            Decimal? @db.Decimal(10, 7)
  zone           String? // KKN, Udon, ...
  province       String?
  preferredDepot String?  @map("preferred_depot") // PTT | Shell | DaoEvo | null
  maxTruckLiters Int?     @map("max_truck_liters")
  deliveryWindow String?  @map("delivery_window") // morning | afternoon | anytime
  contactName    String?  @map("contact_name")
  contactPhone   String?  @map("contact_phone")
  // Distance cache to each depot (km) — recomputed when lat/lng changes
  distPttKm      Decimal? @map("dist_ptt_km") @db.Decimal(6, 1)
  distShellKm    Decimal? @map("dist_shell_km") @db.Decimal(6, 1)
  distDaoKm      Decimal? @map("dist_dao_km") @db.Decimal(6, 1)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org        Organization   @relation(fields: [orgId], references: [id], onDelete: Restrict)
  entity     CustomerEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  fuelOrders FuelOrder[]

  @@index([orgId, isActive])
  @@index([entityId])
  @@index([orgId, zone])
  @@map("delivery_locations")
  @@schema("public")
}

// =============================================================
// 38. customer_quotes — เสนอราคา + Win/Loss + Competitor capture
// FUELOS §3.3 / §5.2 / §12 — capture lost-to in same step (Lean: 1-click)
// =============================================================
model CustomerQuote {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  contactId       String   @map("contact_id") @db.Uuid
  salesId         String   @map("sales_id") @db.Uuid
  productType     String   @map("product_type") // B7 | B10 | 91 | 95
  quoteDate       DateTime @map("quote_date") @db.Date
  depotPrice      Decimal  @map("depot_price") @db.Decimal(10, 4)
  zoneMargin      Decimal  @map("zone_margin") @db.Decimal(10, 4)
  salesMargin     Decimal  @map("sales_margin") @db.Decimal(10, 4) // +N สตาง
  finalPrice      Decimal  @map("final_price") @db.Decimal(10, 4)
  status          String   @default("pending") // pending | won | lost | declined | no_response
  lostTo          String?  @map("lost_to") // competitor name
  competitorPrice Decimal? @map("competitor_price") @db.Decimal(10, 4)
  resultOrderId   String?  @map("result_order_id") @db.Uuid
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sales   User         @relation("QuoteSales", fields: [salesId], references: [id], onDelete: Restrict)

  @@index([orgId, quoteDate])
  @@index([contactId, quoteDate])
  @@index([salesId, quoteDate])
  @@index([orgId, status])
  @@map("customer_quotes")
  @@schema("public")
}

// =============================================================
// 39. price_alert_log — บันทึกว่าแจ้งราคาให้ใครแล้ววันนี้ — FUELOS §12
// ป้องกัน "ลืมแจ้ง" + วัด conversion ของการแจ้งราคา
// =============================================================
model PriceAlertLog {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  contactId   String    @map("contact_id") @db.Uuid
  salesId     String    @map("sales_id") @db.Uuid
  alertDate   DateTime  @map("alert_date") @db.Date
  priceSent   Decimal   @map("price_sent") @db.Decimal(10, 4)
  productType String    @map("product_type")
  sentAt      DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  result      String    @default("pending") // pending | ordered | declined | no_response
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sales   User         @relation("PriceAlertSales", fields: [salesId], references: [id], onDelete: Restrict)

  @@unique([contactId, alertDate, productType])
  @@index([orgId, alertDate])
  @@index([salesId, alertDate])
  @@map("price_alert_log")
  @@schema("public")
}

// =============================================================
// 40. line_response_log — Response Time tracking — FUELOS §6 / §12
// KPI: เวลาเฉลี่ยตอบลูกค้าใน LINE group (target ≤30 นาที)
// =============================================================
model LineResponseLog {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  contactId       String    @map("contact_id") @db.Uuid
  salesId         String?   @map("sales_id") @db.Uuid
  lineGroupId     String?   @map("line_group_id")
  customerSentAt  DateTime  @map("customer_sent_at") @db.Timestamptz(6)
  salesRepliedAt  DateTime? @map("sales_replied_at") @db.Timestamptz(6)
  responseMinutes Int?      @map("response_minutes") // computed at reply time
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sales   User?        @relation("LineResponseSales", fields: [salesId], references: [id], onDelete: SetNull)

  @@index([orgId, customerSentAt])
  @@index([salesId, customerSentAt])
  @@index([contactId, customerSentAt])
  @@map("line_response_log")
  @@schema("public")
}

// =============================================================
// 41. fuel_orders — ออเดอร์น้ำมันจริง — FUELOS §12
// Note: kept distinct name from any future generic `Order` to avoid collision
// =============================================================
model FuelOrder {
  id                    String    @id @default(uuid()) @db.Uuid
  orgId                 String    @map("org_id") @db.Uuid
  orderNumber           String    @unique @map("order_number")
  entityId              String    @map("entity_id") @db.Uuid
  locationId            String    @map("location_id") @db.Uuid
  salesId               String    @map("sales_id") @db.Uuid
  productType           String    @map("product_type")
  qtyOrdered            Decimal   @map("qty_ordered") @db.Decimal(12, 3)
  qtyDelivered          Decimal?  @map("qty_delivered") @db.Decimal(12, 3)
  pricePerLiter         Decimal   @map("price_per_liter") @db.Decimal(10, 4)
  depotCost             Decimal   @map("depot_cost") @db.Decimal(10, 4)
  transportCostPerLiter Decimal   @default(0) @map("transport_cost_per_liter") @db.Decimal(10, 4)
  // marginPerLiter + totalAmount + totalProfit are GENERATED columns added in SQL migration
  // (Prisma cannot express GENERATED columns yet; modeled as nullable read-only here)
  marginPerLiter        Decimal?  @map("margin_per_liter") @db.Decimal(10, 4)
  totalAmount           Decimal?  @map("total_amount") @db.Decimal(15, 2)
  totalProfit           Decimal?  @map("total_profit") @db.Decimal(15, 2)
  truckId               String?   @map("truck_id") @db.Uuid
  driverId              String?   @map("driver_id") @db.Uuid // FK -> users (driver)
  depot                 String?
  status                String    @default("pending") // pending | scheduled | dispatched | delivered | cancelled
  scheduledDate         DateTime? @map("scheduled_date") @db.Date
  deliveredAt           DateTime? @map("delivered_at") @db.Timestamptz(6)
  deliveryPhotoKey      String?   @map("delivery_photo_key")
  deliveryLat           Decimal?  @map("delivery_lat") @db.Decimal(10, 7)
  deliveryLng           Decimal?  @map("delivery_lng") @db.Decimal(10, 7)
  source                String    @default("manual") // quote | flash_sale | manual | line_bot
  sourceQuoteId         String?   @map("source_quote_id") @db.Uuid
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  entity          CustomerEntity   @relation(fields: [entityId], references: [id], onDelete: Restrict)
  location        DeliveryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sales           User             @relation("FuelOrderSales", fields: [salesId], references: [id], onDelete: Restrict)
  truck           Truck?           @relation(fields: [truckId], references: [id], onDelete: SetNull)
  driverLocations DriverLocation[]

  @@index([orgId, scheduledDate])
  @@index([orgId, status])
  @@index([entityId, scheduledDate])
  @@index([salesId, scheduledDate])
  @@index([truckId, scheduledDate])
  @@map("fuel_orders")
  @@schema("public")
}

// =============================================================
// 42. trucks — ทะเบียน + capacity — FUELOS §12
// Reuses Vehicle (DocuFlow scope) for documents. Truck = FuelOS-specific fields.
// =============================================================
model Truck {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  vehicleId       String   @unique @map("vehicle_id") @db.Uuid // 1-1 with Vehicle
  capacityLiters  Int      @map("capacity_liters")
  homeDepot       String?  @map("home_depot") // PTT | Shell | DaoEvo
  status          String   @default("idle") // idle | loaded | dispatched | maintenance
  currentDriverId String?  @map("current_driver_id") @db.Uuid
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org        Organization    @relation(fields: [orgId], references: [id], onDelete: Restrict)
  vehicle    Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  fuelOrders FuelOrder[]
  drivers    DriverProfile[] @relation("DriverCurrentTruck")

  @@index([orgId, isActive])
  @@index([orgId, status])
  @@map("trucks")
  @@schema("public")
}

// =============================================================
// 43. driver_profiles — satellite for User.role=driver — FUELOS §12
// Adds FCM token + current truck assignment without forking User identity
// =============================================================
model DriverProfile {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid // 1-1 with User
  androidFcmToken String?  @map("android_fcm_token")
  currentTruckId  String?  @map("current_truck_id") @db.Uuid
  status          String   @default("offline") // offline | available | on_route | break
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org          Organization     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentTruck Truck?           @relation("DriverCurrentTruck", fields: [currentTruckId], references: [id], onDelete: SetNull)
  locations    DriverLocation[]

  @@index([orgId, status])
  @@map("driver_profiles")
  @@schema("public")
}

// =============================================================
// 44. driver_locations — GPS track per order — FUELOS §12
// Phase 1: Android phone GPS via Driver PWA. Phase 2: hardware GPS.
// =============================================================
model DriverLocation {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  driverId   String   @map("driver_id") @db.Uuid
  orderId    String?  @map("order_id") @db.Uuid
  lat        Decimal  @db.Decimal(10, 7)
  lng        Decimal  @db.Decimal(10, 7)
  speedKmh   Decimal? @map("speed_kmh") @db.Decimal(5, 1)
  recordedAt DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)

  org    Organization  @relation(fields: [orgId], references: [id], onDelete: Restrict)
  driver DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)
  order  FuelOrder?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([driverId, recordedAt])
  @@index([orderId, recordedAt])
  @@map("driver_locations")
  @@schema("public")
}

// =============================================================
// 45. payments — รับชำระ — FUELOS §12 / §14.4
// =============================================================
model Payment {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  entityId    String   @map("entity_id") @db.Uuid
  amount      Decimal  @db.Decimal(15, 2)
  method      String // transfer | cash | cheque
  paymentDate DateTime @map("payment_date") @db.Date
  reference   String? // bank ref, slip number
  notes       String?
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Restrict)
  entity    CustomerEntity   @relation(fields: [entityId], references: [id], onDelete: Restrict)
  createdBy User?            @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  cheques   ChequeTracking[]

  @@index([orgId, paymentDate])
  @@index([entityId, paymentDate])
  @@map("payments")
  @@schema("public")
}

// =============================================================
// 46. flash_sales — Broadcast offer — FUELOS §11
// =============================================================
model FlashSale {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  productType      String   @map("product_type")
  qtyAvailable     Decimal  @map("qty_available") @db.Decimal(12, 3)
  qtySold          Decimal  @default(0) @map("qty_sold") @db.Decimal(12, 3)
  discountPerLiter Decimal  @map("discount_per_liter") @db.Decimal(10, 4)
  zoneFilter       String[] @default([]) @map("zone_filter")
  expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
  status           String   @default("active") // active | sold_out | expired | cancelled
  createdById      String?  @map("created_by_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  createdBy User?        @relation("FlashSaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([orgId, expiresAt])
  @@map("flash_sales")
  @@schema("public")
}

// =============================================================
// 47. credit_documents — link CustomerEntity ↔ DocuFlow Document — FUELOS §14.2
// (e.g. สัญญาซื้อขายน้ำมัน, หนังสือรับรองบริษัท, สำเนาบัตร, statement, หลักประกัน)
// =============================================================
model CreditDocument {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String    @map("org_id") @db.Uuid
  entityId   String    @map("entity_id") @db.Uuid
  documentId String?   @map("document_id") @db.Uuid // FK -> documents (DocuFlow); null = required but not yet uploaded
  docType    String    @map("doc_type") // contract | cert | id | statement | collateral
  expiryDate DateTime? @map("expiry_date") @db.Date
  status     String    @default("pending") // valid | expired | missing | pending
  uploadedAt DateTime? @map("uploaded_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org    Organization   @relation(fields: [orgId], references: [id], onDelete: Restrict)
  entity CustomerEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, docType])
  @@index([orgId, status])
  @@index([orgId, expiryDate])
  @@map("credit_documents")
  @@schema("public")
}

// =============================================================
// 48. cheque_tracking — เช็คที่รับชำระ + วันขึ้นเงิน + bounce flag — FUELOS §14.4
// =============================================================
model ChequeTracking {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String    @map("org_id") @db.Uuid
  entityId      String    @map("entity_id") @db.Uuid
  paymentId     String?   @map("payment_id") @db.Uuid
  chequeNumber  String    @map("cheque_number")
  bank          String
  amount        Decimal   @db.Decimal(15, 2)
  dueDate       DateTime  @map("due_date") @db.Date
  status        String    @default("pending") // pending | cleared | bounced
  clearedAt     DateTime? @map("cleared_at") @db.Timestamptz(6)
  bouncedReason String?   @map("bounced_reason")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Restrict)
  entity  CustomerEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)
  payment Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([orgId, dueDate])
  @@index([orgId, status])
  @@index([entityId, dueDate])
  @@map("cheque_tracking")
  @@schema("public")
}

// =============================================================
// CLAWFLEET — ระบบบริหารตู้คีบ + ตู้แลกเหรียญ
// Spec: docs/CLAWFLEET_PLAN.md (v2 · 2026-05-21)
// 9 tables · token-exchange group cross-check · multi-branch
// =============================================================

enum CfMachineKind {
  CLAW
  EXCHANGER

  @@schema("public")
}

enum CfEventType {
  INITIAL // กรอกครั้งเดียวตอนตั้งตู้ใหม่
  COLLECTION // รอบเก็บปกติ
  VOID // soft delete event

  @@schema("public")
}

enum CfStockMoveType {
  RECEIVE // รับสินค้าเข้าคลัง
  LOAD_TO_MACHINE // เติมเข้าตู้
  COUNT_SNAPSHOT // นับสต๊อกวันนี้
  ADJUST // ปรับมือ (require approve)

  @@schema("public")
}

enum CfSessionStatus {
  OPEN
  CLOSED
  ANOMALY_REVIEW
  LOCKED

  @@schema("public")
}

enum CfDeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  CANCELLED

  @@schema("public")
}

enum CfProductCategory {
  PLUSH // ตุ๊กตา
  TOY // ของเล่น
  UTILITY // ของใช้
  MYSTERY_BOX // กล่องสุ่ม
  MODEL // โมเดล
  KEYCHAIN // พวงกุญแจ
  SNACK // ขนม
  OTHER

  @@schema("public")
}

// =============================================================
// CF.1 — cf_machines (ทุกตู้: CLAW + EXCHANGER)
// =============================================================
model CfMachine {
  id               String        @id @default(uuid()) @db.Uuid
  orgId            String        @map("org_id") @db.Uuid
  branchId         String        @map("branch_id") @db.Uuid
  groupId          String?       @map("group_id") @db.Uuid
  code             String // "CW-001" หรือ "EX-01"
  nickname         String?
  kind             CfMachineKind
  qrToken          String        @unique @map("qr_token") // สำหรับ scan ก่อนกรอก
  serial           String?
  // mirror (updated via AFTER INSERT trigger on cf_collection_events)
  lastCoinMeter    Int           @default(0) @map("last_coin_meter")
  lastDollMeter    Int           @default(0) @map("last_doll_meter")
  lastDollStock    Int           @default(0) @map("last_doll_stock")
  lastEventAt      DateTime?     @map("last_event_at") @db.Timestamptz(6)
  // initial values (กรอกตอนสร้างตู้ · ใช้ตอน INITIAL event)
  initialCoinMeter Int           @default(0) @map("initial_coin_meter")
  initialDollMeter Int           @default(0) @map("initial_doll_meter")
  installedAt      DateTime?     @map("installed_at") @db.Date
  retiredAt        DateTime?     @map("retired_at") @db.Timestamptz(6)
  isActive         Boolean       @default(true) @map("is_active")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  org               Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch            Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  group             CfMachineGroup?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  loadouts          CfMachineLoadout[]
  exchangerLoadouts CfExchangerLoadout[]
  events            CfCollectionEvent[]
  exchangerOfGroup  CfMachineGroup?      @relation("CfGroupExchanger")
  stockMovements    CfStockMovement[]

  @@unique([orgId, code])
  @@index([orgId, branchId, kind, isActive])
  @@index([orgId, groupId])
  @@map("cf_machines")
  @@schema("public")
}

// =============================================================
// CF.2 — cf_machine_groups (1 EX + N CLAW)
// =============================================================
model CfMachineGroup {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  branchId     String   @map("branch_id") @db.Uuid
  name         String // "โซน A ชุมพวง"
  exchangerId  String?  @unique @map("exchanger_id") @db.Uuid // 1 group = 1 ตู้แลก
  toleranceBps Int      @default(500) @map("tolerance_bps") // 500 = 5%
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org       Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  exchanger CfMachine?            @relation("CfGroupExchanger", fields: [exchangerId], references: [id], onDelete: SetNull)
  machines  CfMachine[]
  sessions  CfCollectionSession[]

  @@index([orgId, branchId, isActive])
  @@map("cf_machine_groups")
  @@schema("public")
}

// =============================================================
// CF.3 — cf_products (สินค้าในตู้)
// =============================================================
model CfProduct {
  id                String            @id @default(uuid()) @db.Uuid
  orgId             String            @map("org_id") @db.Uuid
  sku               String
  name              String
  category          CfProductCategory @default(PLUSH)
  defaultPriceCoins Int               @default(1) @map("default_price_coins") // ค่าเล่นเริ่มต้น (จำนวนเหรียญ/ครั้ง)
  unitCostCents     Int               @default(0) @map("unit_cost_cents") // ราคาทุน
  imageUrl          String?           @map("image_url")
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  org            Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  loadouts       CfMachineLoadout[]
  stockMovements CfStockMovement[]

  @@unique([orgId, sku])
  @@index([orgId, category, isActive])
  @@map("cf_products")
  @@schema("public")
}

// =============================================================
// CF.4 — cf_machine_loadouts (CLAW: สินค้า + ราคา/ครั้ง ใน effective period)
// =============================================================
model CfMachineLoadout {
  id                String    @id @default(uuid()) @db.Uuid
  orgId             String    @map("org_id") @db.Uuid
  machineId         String    @map("machine_id") @db.Uuid
  productId         String    @map("product_id") @db.Uuid
  pricePerPlayCoins Int       @default(1) @map("price_per_play_coins") // ค่าเล่น (เหรียญ/ครั้ง · ปกติ 1 เหรียญ = 10฿)
  effectiveFrom     DateTime  @default(now()) @map("effective_from") @db.Timestamptz(6)
  effectiveTo       DateTime? @map("effective_to") @db.Timestamptz(6)
  setById           String?   @map("set_by_id") @db.Uuid
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  machine CfMachine    @relation(fields: [machineId], references: [id], onDelete: Cascade)
  product CfProduct    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orgId, machineId, effectiveTo])
  @@index([orgId, productId])
  @@map("cf_machine_loadouts")
  @@schema("public")
}

// =============================================================
// CF.5 — cf_exchanger_loadouts (EXCHANGER: rate + promo tiers)
// =============================================================
model CfExchangerLoadout {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  machineId       String    @map("machine_id") @db.Uuid
  // base rate: ฿1 → กี่เหรียญ (default 1.0)
  baseCoinPerBaht Decimal   @default(1.0) @map("base_coin_per_baht") @db.Decimal(8, 4)
  // promo tiers JSON [{thb:100, coins:11}, {thb:500, coins:60}]
  promoTiers      Json      @default("[]") @map("promo_tiers")
  effectiveFrom   DateTime  @default(now()) @map("effective_from") @db.Timestamptz(6)
  effectiveTo     DateTime? @map("effective_to") @db.Timestamptz(6)
  setById         String?   @map("set_by_id") @db.Uuid
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  machine CfMachine    @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([orgId, machineId, effectiveTo])
  @@map("cf_exchanger_loadouts")
  @@schema("public")
}

// =============================================================
// CF.6 — cf_collection_sessions (รอบเก็บกลุ่ม · cross-check ที่นี่)
// =============================================================
model CfCollectionSession {
  id                String          @id @default(uuid()) @db.Uuid
  orgId             String          @map("org_id") @db.Uuid
  groupId           String?         @map("group_id") @db.Uuid
  branchId          String?         @map("branch_id") @db.Uuid
  sessionCode       String          @map("session_code") // CFS-2569-NNNNNN · unique per org (not global)
  openedAt          DateTime        @default(now()) @map("opened_at") @db.Timestamptz(6)
  openedById        String          @map("opened_by_id") @db.Uuid
  closedAt          DateTime?       @map("closed_at") @db.Timestamptz(6)
  closedById        String?         @map("closed_by_id") @db.Uuid
  status            CfSessionStatus @default(OPEN)
  // group cross-check result (filled by trigger ที่ status = CLOSED · legacy group model)
  exchangerCoinsOut Int?            @map("exchanger_coins_out")
  clawCoinsIn       Int?            @map("claw_coins_in")
  coinVarianceBps   Int?            @map("coin_variance_bps")
  // v2 branch cross-check snapshot (filled app-layer at close · cash + prize)
  expectedCashCents Int?            @map("expected_cash_cents")
  actualCashCents   Int?            @map("actual_cash_cents")
  cashVarianceBps   Int?            @map("cash_variance_bps")
  prizeMeterOut     Int?            @map("prize_meter_out")
  prizeCountedOut   Int?            @map("prize_counted_out")
  prizeVariance     Int?            @map("prize_variance")
  totalCashCents    Int             @default(0) @map("total_cash_cents")
  anomalyFlags      String[]        @default([]) @map("anomaly_flags")
  reviewerId        String?         @map("reviewer_id") @db.Uuid
  reviewedAt        DateTime?       @map("reviewed_at") @db.Timestamptz(6)
  reviewNote        String?         @map("review_note")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  org      Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  group    CfMachineGroup?     @relation(fields: [groupId], references: [id], onDelete: Restrict)
  branch   Branch?             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  openedBy User                @relation("CfSessionOpener", fields: [openedById], references: [id], onDelete: Restrict)
  closedBy User?               @relation("CfSessionCloser", fields: [closedById], references: [id], onDelete: SetNull)
  reviewer User?               @relation("CfSessionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  events   CfCollectionEvent[]

  @@unique([orgId, sessionCode])
  @@index([orgId, groupId, openedAt(sort: Desc)])
  @@index([orgId, branchId, openedAt(sort: Desc)])
  @@index([orgId, status])
  @@map("cf_collection_sessions")
  @@schema("public")
}

// =============================================================
// CF.7 — cf_collection_events (รายตู้ใน session)
// =============================================================
model CfCollectionEvent {
  id                  String      @id @default(uuid()) @db.Uuid
  orgId               String      @map("org_id") @db.Uuid
  sessionId           String?     @map("session_id") @db.Uuid // null สำหรับ INITIAL/VOID
  machineId           String      @map("machine_id") @db.Uuid
  eventType           CfEventType @default(COLLECTION) @map("event_type")
  collectedAt         DateTime    @map("collected_at") @db.Timestamptz(6)
  collectedById       String      @map("collected_by_id") @db.Uuid
  // ทุก kind
  coinMeterBefore     Int         @map("coin_meter_before")
  coinMeterAfter      Int         @map("coin_meter_after")
  cashCountedCents    Int         @map("cash_counted_cents")
  // CLAW only (nullable for EXCHANGER)
  dollMeterBefore     Int?        @map("doll_meter_before")
  dollMeterAfter      Int?        @map("doll_meter_after")
  stockBefore         Int?        @map("stock_before")
  stockAfter          Int?        @map("stock_after")
  refillQty           Int?        @map("refill_qty")
  // EXCHANGER only (nullable for CLAW)
  promoCoinsDispensed Int?        @map("promo_coins_dispensed") // เหรียญที่แจกจาก promo (รวมใน meter แล้ว · บันทึกแยกเพื่อ G6)
  // photos (R2 URLs) · 5 per machine in v2 (coin meter · prize meter · prize before · prize after · cash)
  photoMeterBeforeUrl String?     @map("photo_meter_before_url")
  photoPrizeMeterUrl  String?     @map("photo_prize_meter_url")
  photoCashUrl        String?     @map("photo_cash_url")
  photoMeterAfterUrl  String?     @map("photo_meter_after_url")
  photoStockUrl       String?     @map("photo_stock_url")
  photosPurgedAt      DateTime?   @map("photos_purged_at") @db.Timestamptz(6)
  // anomaly flags ราย event (เก็บแยกจาก session-level)
  anomalyFlags        String[]    @default([]) @map("anomaly_flags")
  notes               String?
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  org         Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  session     CfCollectionSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  machine     CfMachine            @relation(fields: [machineId], references: [id], onDelete: Restrict)
  collectedBy User                 @relation("CfEventCollector", fields: [collectedById], references: [id], onDelete: Restrict)

  @@index([orgId, machineId, collectedAt(sort: Desc)])
  @@index([sessionId])
  @@index([orgId, eventType, collectedAt(sort: Desc)])
  @@map("cf_collection_events")
  @@schema("public")
}

// =============================================================
// CF.8 — cf_stock_movements (รับเข้า + เติมเข้าตู้ + นับ + ปรับ)
// =============================================================
model CfStockMovement {
  id            String          @id @default(uuid()) @db.Uuid
  orgId         String          @map("org_id") @db.Uuid
  branchId      String          @map("branch_id") @db.Uuid
  type          CfStockMoveType
  productId     String          @map("product_id") @db.Uuid
  machineId     String?         @map("machine_id") @db.Uuid // null สำหรับ RECEIVE / COUNT
  qty           Int // +/− signed (RECEIVE=+, LOAD_TO_MACHINE=-, COUNT=actual, ADJUST=delta)
  refTable      String?         @map("ref_table") // 'cf_collection_events' for LOAD
  refId         String?         @map("ref_id") @db.Uuid
  unitCostCents Int             @default(0) @map("unit_cost_cents") // snapshot ราคาทุนตอน RECEIVE
  receiptR2Key  String?         @map("receipt_r2_key") // ใบเสร็จ
  expectedQty   Int?            @map("expected_qty") // ที่ระบบคาด (สำหรับ COUNT_SNAPSHOT compare)
  varianceQty   Int?            @map("variance_qty") // expected - actual (สำหรับ COUNT)
  reason        String?
  occurredAt    DateTime        @map("occurred_at") @db.Timestamptz(6)
  createdById   String          @map("created_by_id") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product   CfProduct    @relation(fields: [productId], references: [id], onDelete: Restrict)
  machine   CfMachine?   @relation(fields: [machineId], references: [id], onDelete: SetNull)
  createdBy User         @relation("CfStockCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([orgId, branchId, occurredAt(sort: Desc)])
  @@index([orgId, productId, occurredAt(sort: Desc)])
  @@index([orgId, type, occurredAt(sort: Desc)])
  @@index([machineId, occurredAt(sort: Desc)])
  @@map("cf_stock_movements")
  @@schema("public")
}

// =============================================================
// CF.9 — cf_deliveries (v2 · central-warehouse shipments to a branch)
// =============================================================
model CfDelivery {
  id           String           @id @default(uuid()) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  branchId     String           @map("branch_id") @db.Uuid
  status       CfDeliveryStatus @default(SCHEDULED)
  fromLocation String           @default("คลังกลาง บางนา") @map("from_location")
  eta          DateTime?        @db.Timestamptz(6)
  itemsCount   Int              @default(0) @map("items_count")
  unitsCount   Int              @default(0) @map("units_count")
  note         String?
  createdById  String           @map("created_by_id") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  createdBy User         @relation("CfDeliveryCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([orgId, branchId, eta(sort: Desc)])
  @@index([orgId, status])
  @@map("cf_deliveries")
  @@schema("public")
}

// =============================================================
// ChairOps — massage-chair management for 30 branches
// Lives in `chairops` schema (multi-schema · separate from public)
// Source: /Users/patipantantikul/Code/chairops/prisma/schema.prisma
// Renamed: User→ChairopsUser · Branch→ChairopsBranch · AuditLog→ChairopsAuditLog
//          UserRole→ChairopsUserRole (Pool already has UserRole)
// =============================================================

enum ChairopsUserRole {
  ADMIN
  CEO
  MANAGER
  OFFICE
  MAID
  TECHNICIAN

  @@schema("chairops")
}

enum ChairopsAlertLevel {
  INFO
  WARN
  CRITICAL

  @@schema("chairops")
}

enum ChairopsAlertStatus {
  OPEN
  ACK
  RESOLVED
  IGNORED

  @@schema("chairops")
}

enum ChairopsAlertKind {
  SHORTAGE
  MISSED_COLLECTION
  POS_NOT_INGESTED
  CHAIR_OFFLINE
  CLEANLINESS_FAIL
  REPAIR_OVERDUE
  WRITE_OFF_REQUESTED

  @@schema("chairops")
}

enum ChairopsTicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_PARTS
  DONE
  CANCELLED

  @@schema("chairops")
}

enum ChairopsCleanlinessGrade {
  PASS
  WARN
  FAIL

  @@schema("chairops")
}

model ChairopsBranch {
  id          String    @id @default(uuid())
  orgId       String
  slug        String
  name        String
  tabName     String
  parenNumber Int?
  city        String?
  region      String?
  mallGroup   String?
  floor       String?
  isActive    Boolean   @default(true)
  openedAt    DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Cost fields (admin-tier visibility only · per SPEC §2.11 Owner pre-commit #1)
  monthlyRent     Decimal? @db.Decimal(12, 2)
  monthlyUtility  Decimal? @db.Decimal(12, 2)
  monthlyStaff    Decimal? @db.Decimal(12, 2)
  monthlyOther    Decimal? @db.Decimal(12, 2)
  securityDeposit Decimal? @db.Decimal(12, 2)

  // Drift refactor (SPEC §2.3) — anchors per-branch reconcile window
  lastReconcileClosedAt DateTime?

  // Alert routing (Owner pre-commit #2 · SPEC §2.11)
  secondaryAlertUserId String?
  secondaryAlertUser   ChairopsUser? @relation("chairops_secondary_alert", fields: [secondaryAlertUserId], references: [id])

  chairs             ChairopsChair[]
  chairMovesFrom     ChairopsChairMove[]          @relation("chairmove_from")
  chairMovesTo       ChairopsChairMove[]          @relation("chairmove_to")
  maidAssignments    ChairopsMaidAssignment[]
  posDaily           ChairopsPosDaily[]
  cashCollections    ChairopsCashCollection[]
  cashDeposits       ChairopsCashDeposit[]
  drifts             ChairopsDrift[]
  alerts             ChairopsAlert[]
  damageTickets      ChairopsDamageTicket[]
  cleanlinessReports ChairopsCleanlinessReport[]
  dailyRevenue       ChairopsBranchDailyRevenue[]
  cashEvents         ChairopsPosCashEvent[]
  coinEvents         ChairopsPosCoinEvent[]

  @@unique([orgId, slug])
  @@unique([orgId, tabName])
  @@index([orgId])
  @@schema("chairops")
}

model ChairopsUser {
  id              String           @id @default(uuid())
  orgId           String
  // Links to Supabase auth.users.id — same id space as Pool's users
  authUserId      String?
  email           String?
  phone           String?
  lineUserId      String?
  displayName     String
  role            ChairopsUserRole
  isActive        Boolean          @default(true)
  primaryBranchId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  maidAssignments        ChairopsMaidAssignment[]
  cashCollections        ChairopsCashCollection[]
  cashDeposits           ChairopsCashDeposit[]
  chairMovesBy           ChairopsChairMove[]
  posDailyEntries        ChairopsPosDaily[]
  damageReported         ChairopsDamageTicket[]      @relation("chairops_damage_reported_by")
  damageAssigned         ChairopsDamageTicket[]      @relation("chairops_damage_assigned_to")
  cleanlinessByMaid      ChairopsCleanlinessReport[] @relation("chairops_cleanliness_by_maid")
  cleanlinessByAuditor   ChairopsCleanlinessReport[] @relation("chairops_cleanliness_by_auditor")
  auditLogs              ChairopsAuditLog[]
  alertsAcked            ChairopsAlert[]             @relation("chairops_alerts_acked_by")
  writeOffsByMaker       ChairopsWriteOff[]          @relation("chairops_writeoffs_maker")
  writeOffsByApprover    ChairopsWriteOff[]          @relation("chairops_writeoffs_approver")
  branchesSecondaryAlert ChairopsBranch[]            @relation("chairops_secondary_alert")

  @@unique([orgId, authUserId])
  @@unique([orgId, email])
  @@unique([orgId, phone])
  @@unique([orgId, lineUserId])
  @@index([orgId])
  @@index([role])
  @@index([primaryBranchId])
  @@schema("chairops")
}

model ChairopsMaidAssignment {
  id        String    @id @default(uuid())
  orgId     String
  userId    String
  branchId  String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  isActive  Boolean   @default(true)

  user   ChairopsUser   @relation(fields: [userId], references: [id])
  branch ChairopsBranch @relation(fields: [branchId], references: [id])

  @@index([orgId])
  @@index([branchId, isActive])
  @@index([userId, isActive])
  @@schema("chairops")
}

model ChairopsChair {
  id            String    @id @default(uuid())
  orgId         String
  chairCode     String
  branchId      String
  generation    String?
  pricePerCycle Int?
  isOnline      Boolean   @default(true)
  isActive      Boolean   @default(true)
  installedAt   DateTime?
  retiredAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branch        ChairopsBranch         @relation(fields: [branchId], references: [id])
  damageTickets ChairopsDamageTicket[]
  moves         ChairopsChairMove[]

  @@unique([orgId, chairCode])
  @@index([orgId])
  @@index([branchId])
  @@index([generation])
  @@schema("chairops")
}

// Chair-move history (Plan 2 per CEO 2026-05-31). One row per branch change.
// fromBranchId is nullable (first placement when the chair was created).
// source = "manual" | "starthing_import" | other ingest channels.
//
// Revenue rows (PosDaily / CashCollection / BranchDailyRevenue) already
// snapshot branchId at event time, so historical attribution is preserved
// regardless of moves. This table answers "where has chair G0322099 been?"
// without scanning audit_log JSON.
model ChairopsChairMove {
  id           String   @id @default(uuid())
  orgId        String
  chairId      String
  fromBranchId String?
  toBranchId   String
  movedAt      DateTime @default(now())
  movedById    String?
  source       String   @default("manual")
  notes        String?
  createdAt    DateTime @default(now())

  chair      ChairopsChair   @relation(fields: [chairId], references: [id])
  fromBranch ChairopsBranch? @relation("chairmove_from", fields: [fromBranchId], references: [id])
  toBranch   ChairopsBranch  @relation("chairmove_to", fields: [toBranchId], references: [id])
  movedBy    ChairopsUser?   @relation(fields: [movedById], references: [id])

  @@index([orgId])
  @@index([chairId, movedAt])
  @@index([toBranchId, movedAt])
  @@schema("chairops")
}

model ChairopsPosImport {
  id           String    @id @default(uuid())
  orgId        String
  filename     String
  uploadedById String
  uploadedAt   DateTime  @default(now())
  fileHash     String
  rowCount     Int
  diffSummary  Json
  committed    Boolean   @default(false)
  committedAt  DateTime?
  notes        String?

  dailyRevenue ChairopsBranchDailyRevenue[]
  cashEvents   ChairopsPosCashEvent[]
  coinEvents   ChairopsPosCoinEvent[]

  @@unique([orgId, fileHash])
  @@index([orgId])
  @@index([uploadedAt])
  @@schema("chairops")
}

model ChairopsPosDaily {
  id              String   @id @default(uuid())
  orgId           String
  branchId        String
  chairCode       String?
  bizDate         DateTime @db.Date
  onlineTotal     Decimal  @default(0) @db.Decimal(12, 2)
  cashTotal       Decimal  @default(0) @db.Decimal(12, 2)
  coinInsertCount Int      @default(0)
  totalCash       Decimal  @default(0) @db.Decimal(12, 2)
  grossTotal      Decimal  @default(0) @db.Decimal(12, 2)
  rawSource       String?
  importId        String?
  enteredById     String
  enteredAt       DateTime @default(now())
  notes           String?

  branch ChairopsBranch @relation(fields: [branchId], references: [id])
  user   ChairopsUser   @relation(fields: [enteredById], references: [id])

  @@unique([orgId, branchId, chairCode, bizDate])
  @@index([orgId])
  @@index([branchId, bizDate])
  @@index([bizDate])
  @@schema("chairops")
}

model ChairopsCashCollection {
  id               String               @id @default(uuid())
  orgId            String
  branchId         String
  maidId           String
  collectedAt      DateTime             @default(now())
  countedAmount    Int
  // Step-2 deposit columns kept for backward compat with rows written before
  // the deposit-table split (2026-05-30). NEW writes leave these at 0/null
  // and instead create a ChairopsCashDeposit row that this collection's
  // depositId points to. Drift engine sums depositedAmount from the new
  // table.
  depositedAmount  Int                  @default(0)
  evidencePhotoUrl String
  slipPhotoUrl     String?
  imageHash        String
  notes            String?
  // Per-chair breakdown captured by the maid at Step 1. Shape:
  //   { lines: [{ chairCode, status: "collected"|"broken"|"empty"|"skipped",
  //               amount: number, reason?: string, photoUrl?: string }, ...] }
  // countedAmount must equal SUM(line.amount). Nullable for rows written
  // before this column existed (legacy free-text "[CH-001]" prefix in notes).
  chairBreakdown   Json?
  // null = pending deposit · set when maid lumps this round into a
  // ChairopsCashDeposit. Many collections can share one depositId (batch
  // deposit to save bank fees).
  depositId        String?
  deposit          ChairopsCashDeposit? @relation(fields: [depositId], references: [id])
  lockedAt         DateTime?
  unlockedById     String?
  unlockedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  branch ChairopsBranch @relation(fields: [branchId], references: [id])
  maid   ChairopsUser   @relation(fields: [maidId], references: [id])

  @@unique([orgId, imageHash])
  @@index([orgId])
  @@index([branchId, collectedAt])
  @@index([maidId, collectedAt])
  @@index([branchId, depositId])
  @@schema("chairops")
}

// Bank-deposit event — one row per actual trip to the bank, can cover N
// collection rounds (batch deposit to save bank fees per CEO 2026-05-30).
// depositedAmount is what landed in the bank account (≤ sum of covered
// collections.countedAmount in most cases · bankFee separate).
model ChairopsCashDeposit {
  id              String   @id @default(uuid())
  orgId           String
  branchId        String
  maidId          String
  depositedAt     DateTime @default(now())
  depositedAmount Int
  bankFee         Int      @default(0)
  slipPhotoUrl    String
  slipImageHash   String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch      ChairopsBranch           @relation(fields: [branchId], references: [id])
  maid        ChairopsUser             @relation(fields: [maidId], references: [id])
  collections ChairopsCashCollection[]

  @@unique([orgId, slipImageHash])
  @@index([orgId])
  @@index([branchId, depositedAt])
  @@index([maidId, depositedAt])
  @@schema("chairops")
}

model ChairopsDrift {
  id                      String    @id @default(uuid())
  orgId                   String
  branchId                String
  posTotal                Int
  depositTotal            Int
  driftAmount             Int
  driftSince              DateTime?
  lastPosDate             DateTime? @db.Date
  lastCollectionAt        DateTime?
  daysSinceLastCollection Int       @default(0)
  lastComputedAt          DateTime  @default(now())

  branch ChairopsBranch @relation(fields: [branchId], references: [id])

  @@unique([orgId, branchId])
  @@index([orgId])
  @@schema("chairops")
}

model ChairopsAlert {
  id          String              @id @default(uuid())
  orgId       String
  branchId    String?
  kind        ChairopsAlertKind
  level       ChairopsAlertLevel
  status      ChairopsAlertStatus @default(OPEN)
  title       String
  message     String
  contextJson Json?
  ackedById   String?
  ackedAt     DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime            @default(now())

  branch  ChairopsBranch? @relation(fields: [branchId], references: [id])
  ackedBy ChairopsUser?   @relation("chairops_alerts_acked_by", fields: [ackedById], references: [id])

  @@index([orgId])
  @@index([status, level])
  @@index([branchId, status])
  @@index([createdAt])
  @@schema("chairops")
}

model ChairopsWriteOff {
  id         String    @id @default(uuid())
