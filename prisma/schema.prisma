  @@index([orgId, branchId])
  @@index([branchId, startedAt])
  @@index([cashierUserId, startedAt])
  @@map("shifts")
  @@schema("playland")
}

// ---------- 17. Daily Reports (per-branch per-day rollup) ----------
model PlaylandDailyReport {
  id                  String    @id @default(uuid()) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  branchId            String    @map("branch_id") @db.Uuid
  reportDate          DateTime  @map("report_date") @db.Date
  entryRevenueCents   Int       @default(0) @map("entry_revenue_cents")
  productRevenueCents Int       @default(0) @map("product_revenue_cents")
  totalRevenueCents   Int       @default(0) @map("total_revenue_cents")
  memberCount         Int       @default(0) @map("member_count")
  sessionsCompleted   Int       @default(0) @map("sessions_completed")
  sessionsExpired     Int       @default(0) @map("sessions_expired")
  sessionsForfeited   Int       @default(0) @map("sessions_forfeited")
  productsSold        Int       @default(0) @map("products_sold")
  alertsCount         Int       @default(0) @map("alerts_count")
  breakdown           Json? // per-package, per-product, per-hour breakdown
  cashScannedIn       Int       @default(0) @map("cash_scanned_in") // anti-fraud: face scan count
  cashScannedOut      Int       @default(0) @map("cash_scanned_out")
  fraudVariance       Int       @default(0) @map("fraud_variance") // scan in/out vs paid count
  submittedAt         DateTime? @map("submitted_at") @db.Timestamptz(6)
  submittedByUserId   String?   @map("submitted_by_user_id") @db.Uuid

  branch PlaylandBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, reportDate])
  @@index([orgId, reportDate])
  @@map("daily_reports")
  @@schema("playland")
}

// ---------- 18. Face Sync (Version C — local cache on device) ----------
model PlaylandFaceSync {
