}

// ---------- 16. Shifts (per-cashier per-branch) ----------
model PlaylandShift {
  id                 String              @id @default(uuid()) @db.Uuid
  orgId              String              @map("org_id") @db.Uuid
  branchId           String              @map("branch_id") @db.Uuid
  cashierUserId      String              @map("cashier_user_id") @db.Uuid
  shiftCode          String              @unique @map("shift_code") // SH-YYMMDD-NN
  startedAt          DateTime            @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt            DateTime?           @map("ended_at") @db.Timestamptz(6)
  openingCashCents   Int                 @default(0) @map("opening_cash_cents")
  closingCashCents   Int?                @map("closing_cash_cents")
  expectedCashCents  Int?                @map("expected_cash_cents")
  varianceCents      Int?                @map("variance_cents") // closing - expected
  totalSalesCents    Int                 @default(0) @map("total_sales_cents")
  totalSessionsCents Int                 @default(0) @map("total_sessions_cents")
  status             PlaylandShiftStatus @default(OPEN)
