  @@index([actorUserId, createdAt])
  @@index([category, createdAt])
  @@map("audit_logs")
  @@schema("playland")
}

// =============================================================
// PLAYLAND · Wristband (Harborland-style · /bigfeature W1 · 2026-05-26)
// CEO 2026-05-26: paid kid → cashier issues QR wristband → scan #1 bind →
// scan #2 at gate activates session → scan #3+ picker (ออก / ขายของ)
// =============================================================
enum PlaylandWristbandStatus {
  ISSUED // bound to member · waiting for first gate scan
  ACTIVE // entered through gate at least once
  RETURNED // checked out · returned to cashier
  LOST // marked lost · prevented from re-use

  @@schema("playland")
}

model PlaylandWristband {
  id             String                  @id @default(uuid()) @db.Uuid
  orgId          String                  @map("org_id") @db.Uuid
  branchId       String                  @map("branch_id") @db.Uuid
  code           String                  @unique
  memberId       String?                 @map("member_id") @db.Uuid
  sessionId      String?                 @map("session_id") @db.Uuid
  status         PlaylandWristbandStatus @default(ISSUED)
  issuedAt       DateTime                @default(now()) @map("issued_at") @db.Timestamptz(6)
  issuedByUserId String                  @map("issued_by_user_id") @db.Uuid
  boundAt        DateTime?               @map("bound_at") @db.Timestamptz(6)
  activatedAt    DateTime?               @map("activated_at") @db.Timestamptz(6)
  returnedAt     DateTime?               @map("returned_at") @db.Timestamptz(6)
  lastScanAt     DateTime?               @map("last_scan_at") @db.Timestamptz(6)
  notes          String?
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  member  PlaylandMember?         @relation(fields: [memberId], references: [id])
  session PlaylandSession?        @relation(fields: [sessionId], references: [id])
  scans   PlaylandWristbandScan[]

  @@index([orgId, branchId])
  @@index([memberId])
  @@index([status])
  @@map("wristbands")
  @@schema("playland")
}

model PlaylandWristbandScan {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  wristbandId     String   @map("wristband_id") @db.Uuid
  scannedByUserId String?  @map("scanned_by_user_id") @db.Uuid
  scanType        String // BIND / GATE_IN / GATE_OUT / POS_CHARGE / EXIT / LOOKUP
  outcome         String // ok / blocked / error / picker_shown
  metadata        Json?
  scannedAt       DateTime @default(now()) @map("scanned_at") @db.Timestamptz(6)

  wristband PlaylandWristband @relation(fields: [wristbandId], references: [id], onDelete: Cascade)

  @@index([wristbandId, scannedAt])
  @@map("wristband_scans")
  @@schema("playland")
}

enum InboxPlatform {
  LINE
  FACEBOOK

  @@schema("public")
}

enum InboxDirection {
  IN
  OUT

  @@schema("public")
}

enum InboxConversationStatus {
  OPEN
  SNOOZED
  CLOSED

  @@schema("public")
}

model InboxChannel {
  id             String        @id @default(uuid()) @db.Uuid
  orgId          String        @map("org_id") @db.Uuid
  platform       InboxPlatform
  displayName    String        @map("display_name") // "เก้าอี้นวด LINE", "Pooil FB"
  businessTag    String?       @map("business_tag") // groups channels by business: "chairops" | "pooil" | ...
  externalId     String?       @map("external_id") // LINE Channel ID / FB Page ID
  accessTokenEnc String?       @map("access_token_enc") // encrypted long-lived token
  webhookSecret  String?       @map("webhook_secret") // encrypted provider signing secret
  botEnabled     Boolean       @default(false) @map("bot_enabled") // auto-reply ON only for chairops
  status         String        @default("setup") // setup | active | error | disabled
  lastEventAt    DateTime?     @map("last_event_at") @db.Timestamptz(6)
  metadata       Json?
  createdById    String?       @map("created_by_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  conversations InboxConversation[]
  messages      InboxMessage[]

  @@index([orgId, platform])
  @@index([orgId, businessTag])
  @@map("inbox_channels")
  @@schema("public")
}

model InboxConversation {
  id             String                  @id @default(uuid()) @db.Uuid
  orgId          String                  @map("org_id") @db.Uuid
  channelId      String                  @map("channel_id") @db.Uuid
  platform       InboxPlatform
  externalUserId String                  @map("external_user_id") // LINE userId / FB PSID
  displayName    String?                 @map("display_name")
  status         InboxConversationStatus @default(OPEN)
  topicTag       String?                 @map("topic_tag") // bot-classified: scan_fail|money_lost|buy|feedback|strong|other
  isLead         Boolean                 @default(false) @map("is_lead")
  isUrgent       Boolean                 @default(false) @map("is_urgent")
  needsHuman     Boolean                 @default(false) @map("needs_human") // escalated / bot couldn't answer
  contactPhone   String?                 @map("contact_phone")
  contactNote    String?                 @map("contact_note")
  assignedToId   String?                 @map("assigned_to_id") @db.Uuid
  lastMessageAt  DateTime                @default(now()) @map("last_message_at") @db.Timestamptz(6)
  lastInboundAt  DateTime?               @map("last_inbound_at") @db.Timestamptz(6)
  unreadCount    Int                     @default(0) @map("unread_count")
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  channel  InboxChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages InboxMessage[]

  @@unique([channelId, externalUserId])
  @@index([orgId, status, lastMessageAt(sort: Desc)])
  @@index([orgId, lastMessageAt(sort: Desc)])
  @@map("inbox_conversations")
  @@schema("public")
}

model InboxMessage {
  id             String         @id @default(uuid()) @db.Uuid
  orgId          String         @map("org_id") @db.Uuid
  conversationId String         @map("conversation_id") @db.Uuid
  channelId      String         @map("channel_id") @db.Uuid
  platform       InboxPlatform
  direction      InboxDirection
  body           String
  sentByBot      Boolean        @default(false) @map("sent_by_bot")
  externalId     String?        @map("external_id") // provider-side message ID (idempotency)
  attachments    Json?
  errorMessage   String?        @map("error_message")
  createdById    String?        @map("created_by_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation InboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  channel      InboxChannel      @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Asc)])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("inbox_messages")
  @@schema("public")
}

// Bot knowledge — FAQ pairs (deterministic, free matching · checked before AI)
model InboxBotFaq {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  businessTag String   @map("business_tag") // "chairops"
  intent      String? // optional canonical intent name
  keywords    String // comma/space separated terms used for matching
  answer      String
  enabled     Boolean  @default(true)
  priority    Int      @default(0) // higher = checked first
  hits        Int      @default(0) // times matched
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([orgId, businessTag, enabled])
  @@map("inbox_bot_faqs")
  @@schema("public")
}

// Bot knowledge — free-text business facts (price, hours, branches) used as AI context
model InboxBotKnowledge {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  businessTag String   @map("business_tag")
  title       String
  content     String
  enabled     Boolean  @default(true)
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([orgId, businessTag, enabled])
  @@map("inbox_bot_knowledge")
  @@schema("public")
}

// Per-business bot configuration (tone, contact phone, on/off, daily summary)
model InboxBotSettings {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  businessTag  String   @map("business_tag")
  botEnabled   Boolean  @default(true) @map("bot_enabled")
  tone         String   @default("สุภาพ สั้น เป็นกันเอง")
  botName      String?  @map("bot_name")
  contactPhone String?  @map("contact_phone") // used by scan_fail / money_lost flows
  fallbackText String   @default("ขออภัยค่ะ เดี๋ยวทีมงานติดต่อกลับโดยเร็วที่สุดนะคะ") @map("fallback_text")
  escalateText String?  @map("escalate_text")
  dailySummary Boolean  @default(true) @map("daily_summary")
  flowImages   Json     @default("{}") @map("flow_images") // { money_lost?: url, scan_fail?: url, strong?: url, buy?: url, feedback?: url, intro?: url }
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([orgId, businessTag])
  @@map("inbox_bot_settings")
  @@schema("public")
}

// Training queue — questions the bot couldn't answer (admin fills the answer)
model InboxBotUnanswered {
  id             String   @id @default(uuid()) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  businessTag    String   @map("business_tag")
  conversationId String?  @map("conversation_id") @db.Uuid
  question       String
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orgId, businessTag, resolved])
  @@map("inbox_bot_unanswered")
  @@schema("public")
}

// Cached daily summary per business (one AI call/day · cheap)
model InboxDailySummary {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  businessTag String   @map("business_tag")
  summaryDate DateTime @map("summary_date") @db.Date
  stats       Json
  aiText      String?  @map("ai_text")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([orgId, businessTag, summaryDate])
  @@map("inbox_daily_summaries")
  @@schema("public")
}

// =============================================================
// CostCtrl · ศูนย์ควบคุมต้นทุน (super_admin only)
// BIGFEATURE 2026-05-31 · Pool ERP Module #10
// =============================================================
model CostProvider {
  id             String    @id @default(uuid()) @db.Uuid
  slug           String    @unique
  displayName    String    @map("display_name")
  category       String
  enabled        Boolean   @default(true)
  pricingNote    String?   @map("pricing_note")
  budgetMonthly  Json      @default("{}") @map("budget_monthly")
  lastSyncAt     DateTime? @map("last_sync_at") @db.Timestamptz(6)
  lastSyncStatus String?   @map("last_sync_status")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  snapshots   CostSnapshot[]
  rules       CostAlertRule[]
  credentials CostApiCredential[]

  @@map("cost_provider")
  @@schema("public")
}

model CostSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  providerId  String   @map("provider_id") @db.Uuid
  capturedAt  DateTime @default(now()) @map("captured_at") @db.Timestamptz(6)
  periodMonth DateTime @map("period_month") @db.Date
  metric      String
  unit        String
  value       Decimal  @default(0) @db.Decimal(20, 6)
  costUsd     Decimal  @default(0) @map("cost_usd") @db.Decimal(10, 4)
  raw         Json?
  source      String

  provider CostProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, periodMonth, metric])
  @@index([capturedAt])
  @@map("cost_snapshot")
  @@schema("public")
}

model CostAlertRule {
  id            String   @id @default(uuid()) @db.Uuid
  providerId    String   @map("provider_id") @db.Uuid
  metric        String
  thresholdPct  Decimal? @map("threshold_pct") @db.Decimal(5, 2)
  thresholdAbs  Decimal? @map("threshold_abs") @db.Decimal(20, 6)
  channel       String   @default("line")
  cooldownHours Int      @default(24) @map("cooldown_hours")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  provider CostProvider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  events   CostAlertEvent[]

  @@map("cost_alert_rule")
  @@schema("public")
}

model CostAlertEvent {
  id             String    @id @default(uuid()) @db.Uuid
  ruleId         String    @map("rule_id") @db.Uuid
  triggeredAt    DateTime  @default(now()) @map("triggered_at") @db.Timestamptz(6)
  observedValue  Decimal   @map("observed_value") @db.Decimal(20, 6)
  thresholdValue Decimal   @map("threshold_value") @db.Decimal(20, 6)
  message        String
  notifiedAt     DateTime? @map("notified_at") @db.Timestamptz(6)
  resolvedAt     DateTime? @map("resolved_at") @db.Timestamptz(6)

  rule CostAlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([triggeredAt])
  @@map("cost_alert_event")
  @@schema("public")
}

model CostApiCredential {
  id          String    @id @default(uuid()) @db.Uuid
  providerId  String    @map("provider_id") @db.Uuid
  label       String
  scope       String?
  ciphertext  String
  encVersion  Int       @default(1) @map("enc_version")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(6)
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById String?   @map("created_by_id") @db.Uuid

  provider CostProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, label])
  @@map("cost_api_credential")
  @@schema("public")
}

// =============================================================
// HotelBook · ระบบจองโรงแรม (Pool ERP Module #11)
// BIGFEATURE 2026-05-31 รอบ 68 · Mix Hotel first tenant
// =============================================================
model Hotel {
  id                     String   @id @default(uuid()) @db.Uuid
  orgId                  String   @map("org_id") @db.Uuid
  slug                   String   @unique
  name                   String
  concept                String?
  description            String?
  reservationPhones      String[] @map("reservation_phones")
  ownerPhone             String?  @map("owner_phone")
  googleMapsUrl          String?  @map("google_maps_url")
  address                String?
  email                  String?
  brandColor             String   @default("#7c3aed") @map("brand_color")
  heroImageUrl           String?  @map("hero_image_url")
  logoUrl                String?  @map("logo_url")
  checkInTime            String?  @map("check_in_time")
  checkOutTime           String?  @map("check_out_time")
  is24h                  Boolean  @default(true) @map("is_24h")
  paymentMethods         String[] @default(["cash", "transfer", "qr"]) @map("payment_methods")
  allowsPets             Boolean  @default(false) @map("allows_pets")
  smokingAllowed         Boolean  @default(false) @map("smoking_allowed")
  cancellationNote       String?  @map("cancellation_note")
  multiNightDiscountNote String?  @map("multi_night_discount_note")
  amenities              String[] @default([])
  nearbyPlaces           String[] @default([]) @map("nearby_places")
  enabled                Boolean  @default(true)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rooms    HotelRoom[]
  images   HotelImage[]
  bookings HotelBooking[]

  @@index([orgId])
  @@map("hotel")
  @@schema("public")
}

model HotelRoom {
  id              String   @id @default(uuid()) @db.Uuid
  hotelId         String   @map("hotel_id") @db.Uuid
  slug            String
  name            String
  description     String?
  bedDescription  String?  @map("bed_description")
  priceThb        Decimal  @map("price_thb") @db.Decimal(10, 2)
  totalRooms      Int      @default(1) @map("total_rooms")
  amenities       String[] @default([])
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  primaryImageUrl String?  @map("primary_image_url")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  hotel        Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  images       HotelImage[]
  bookings     HotelBooking[]
  blockedDates HotelBlockedDate[]

  @@unique([hotelId, slug])
  @@map("hotel_room")
  @@schema("public")
}

model HotelImage {
  id           String   @id @default(uuid()) @db.Uuid
  hotelId      String   @map("hotel_id") @db.Uuid
  roomId       String?  @map("room_id") @db.Uuid
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  altText      String?  @map("alt_text")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  hotel Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room  HotelRoom? @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([hotelId, sortOrder])
  @@index([roomId, sortOrder])
  @@map("hotel_image")
  @@schema("public")
}

model HotelBooking {
  id             String   @id @default(uuid()) @db.Uuid
  hotelId        String   @map("hotel_id") @db.Uuid
  roomId         String   @map("room_id") @db.Uuid
  code           String   @unique
  guestName      String   @map("guest_name")
  guestPhone     String   @map("guest_phone")
  guestEmail     String?  @map("guest_email")
  guestLineId    String?  @map("guest_line_id")
  guestFbPsid    String?  @map("guest_fb_psid")
  checkInDate    DateTime @map("check_in_date") @db.Date
  checkOutDate   DateTime @map("check_out_date") @db.Date
  nights         Int
  rooms          Int      @default(1)
  totalAmountThb Decimal  @map("total_amount_thb") @db.Decimal(10, 2)
  paymentMethod  String?  @map("payment_method")
  paymentSlipUrl String?  @map("payment_slip_url")
  status         String   @default("pending")
  source         String
  note           String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  hotel Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room  HotelRoom @relation(fields: [roomId], references: [id])

  @@index([hotelId, checkInDate])
  @@index([roomId, checkInDate, checkOutDate])
  @@map("hotel_booking")
  @@schema("public")
}

model HotelBlockedDate {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @map("room_id") @db.Uuid
  date      DateTime @db.Date
  rooms     Int      @default(1)
  reason    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  room HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("hotel_blocked_date")
  @@schema("public")
}
