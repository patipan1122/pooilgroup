// Pooilgroup ERP — Prisma Schema
// 1 organization "Pooilgroup" → 2 companies (Pooil Oil + JP Sync Group) → 118 branches across 11 business types
// See plan: /Users/patipantantikul/.claude/plans/sunny-splashing-cocoa.md
// Spec source: /Users/patipantantikul/Desktop/pooilgroup/ดีเทลv1/CORE_SYSTEM.md + CASHHUB.md

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================
// 1. organizations — multi-tenant root
// =============================================================
model Organization {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  slug           String   @unique
  logoUrl        String?  @map("logo_url")
  settings       Json     @default("{}")
  lineOaId       String?  @map("line_oa_id")
  telegramChatId String?  @map("telegram_chat_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users            User[]
  companies        Company[]
  branches         Branch[]
  branchRentals    BranchRental[]
  reportTemplates  ReportTemplate[]
  dailyReports     DailyReport[]
  cashShortages    CashShortage[]
  auditLogs        AuditLog[]
  userBranches     UserBranch[]
  notifications    Notification[]
  userSessions     UserSession[]
  registerRequests RegisterRequest[]
  orgModules       OrgModule[]
  branchGroups     BranchGroup[]
  holidays         Holiday[]
  telegramSubs     TelegramSubscription[]
  telegramGroups   TelegramGroup[]
  telegramTokens   TelegramPairingToken[]
  branchTargets    BranchTarget[]
  branchHealthScores BranchHealthScore[]
  branchStreaks    BranchStreak[]
  missingReports   MissingReportReason[]
  documents        Document[]
  documentOwnerships DocumentOwnership[]
  documentTags     DocumentTag[]
  documentRenewals DocumentRenewal[]
  documentSharedBranches DocumentSharedBranch[]
  vehicles         Vehicle[]
  vehicleDocuments VehicleDocument[]
  personDocuments  PersonDocument[]
  signaturePlacements DocumentSignaturePlacement[]
  documentAnalyses DocumentAnalysis[]
  aiSearchCache    AiSearchCache[]

  @@map("organizations")
}

// =============================================================
// 1b. companies — legal entity layer under one Pooilgroup org
// e.g. "Pooil Oil" + "JP Sync Group" (separate VAT, separate accounting)
// Branches attach to a company; users belong to org and may span companies
// =============================================================
model Company {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  code      String // POOIL | JPSYNC
  name      String // "Pooil Oil" | "JP Sync Group"
  taxId     String?  @map("tax_id") // เลขผู้เสียภาษี
  address   String?
  phone     String?
  logoUrl   String?  @map("logo_url")
  brandColor String? @map("brand_color") // optional override per company
  settings  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  branches Branch[]
  vehicles Vehicle[]

  @@unique([orgId, code])
  @@index([orgId, isActive])
  @@map("companies")
}

// =============================================================
// 2. users — auth + RBAC
// =============================================================
enum UserRole {
  super_admin    // Owner — strategic + financial + identity
  admin          // Operational admin — runs day-to-day
  area_manager   // Manages multiple branches in a region/business
  branch_manager // 1-2 per branch
  staff          // Submits reports / works on branch
  driver         // FuelOS Phase 2
  viewer         // Read-only (accountant / HR)
  org_admin      // [deprecated alias — kept for back-compat, will migrate to admin]
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  orgId              String    @map("org_id") @db.Uuid
  employeeCode       String?   @map("employee_code") // referenced from Humansoft HR app
  email              String?   @unique
  name               String
  phone              String?
  passwordHash       String?   @map("password_hash")
  role               UserRole
  lineUserId         String?   @unique @map("line_user_id")
  telegramUserId     String?   @map("telegram_user_id")
  telegramChatId     String?   @map("telegram_chat_id")
  mustChangePassword Boolean   @default(true) @map("must_change_password")
  isActive           Boolean   @default(true) @map("is_active")
  lastLoginAt        DateTime? @map("last_login_at") @db.Timestamptz(6)
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  lockedUntil        DateTime? @map("locked_until") @db.Timestamptz(6)
  invitedBy          String?   @map("invited_by") @db.Uuid
  inviteToken        String?   @unique @map("invite_token")
  inviteExpiresAt    DateTime? @map("invite_expires_at") @db.Timestamptz(6)
  inviteUsedAt       DateTime? @map("invite_used_at") @db.Timestamptz(6)
  // Optional auto-expiry for non-permanent users (auditors, contractors,
  // temp staff). When set + `now() > tempAccessExpiresAt`, the access-review
  // cron deactivates the account. NULL = permanent until manual deactivation.
  // Spec: ดีเทลv1/CORE_SYSTEM.md §2.6 Temporary Access.
  tempAccessExpiresAt DateTime? @map("temp_access_expires_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org                 Organization           @relation(fields: [orgId], references: [id], onDelete: Restrict)
  userBranches        UserBranch[]
  managedBranches     Branch[]               @relation("BranchManager")
  submittedReports    DailyReport[]          @relation("ReportSubmitter")
  approvedReports     DailyReport[]          @relation("ReportApprover")
  unlockedReports     DailyReport[]          @relation("ReportUnlocker")
  shortagesAttributed CashShortage[]         @relation("ShortagePerson")
  auditLogs           AuditLog[]
  notifications       Notification[]
  sessions            UserSession[]
  reviewedRequests    RegisterRequest[]      @relation("RegisterReviewer")
  telegramSubs        TelegramSubscription[]
  telegramTokens      TelegramPairingToken[]
  uploadedDocuments   Document[]            @relation("DocumentUploader")
  responsibleRenewals DocumentRenewal[]     @relation("RenewalResponsible")
  personDocuments     PersonDocument[]
  signaturePlacements DocumentSignaturePlacement[] @relation("SignaturePlacementSigner")

  @@unique([orgId, employeeCode])
  @@index([orgId, isActive])
  @@index([orgId, role])
  @@index([lineUserId])
  @@map("users")
}

// =============================================================
// 3. branches — 30+ สาขา / 7 business types
// =============================================================
enum BusinessType {
  fuel_station       // ปั๊มน้ำมัน
  lpg_station        // ปั๊มแก๊ส (เติมรถ)
  lpg_retail         // ร้านค้าแก๊ส (ขายถัง)
  bottling_plant     // โรงบรรจุก๊าซ
  hotel              // โรงแรม
  convenience_store  // 7-Eleven
  ev_station         // EV Station
  cafe               // Café Amazon
  cafe_punthai       // ร้านกาแฟพันธุ์ไทย
  massage_chair      // เก้าอี้นวด (kiosk)
  claw_machine       // ตู้คีบ (kiosk)
  training_center    // ศูนย์ฝึกอบรม
  transport          // FuelOS Phase 2
  gas_fleet          // FuelOS Phase 2
}

model Branch {
  id             String       @id @default(uuid()) @db.Uuid
  orgId          String       @map("org_id") @db.Uuid
  companyId      String       @map("company_id") @db.Uuid // Pooil Oil or JP Sync
  parentBranchId String?      @map("parent_branch_id") @db.Uuid // host branch for sub-tenants (e.g. 7-11 inside a fuel station)
  code           String
  name           String
  businessType   BusinessType @map("business_type")
  province       String?
  region         String?
  address        String?
  lat            Decimal?     @db.Decimal(10, 7)
  lng            Decimal?     @db.Decimal(10, 7)
  managerId      String?      @map("manager_id") @db.Uuid
  phone          String?
  lineGroupId    String?      @map("line_group_id")
  reportDeadline String       @default("21:00") @map("report_deadline") // HH:mm string for simplicity
  settings       Json         @default("{}")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  org             Organization          @relation(fields: [orgId], references: [id], onDelete: Restrict)
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  parentBranch    Branch?               @relation("SubTenants", fields: [parentBranchId], references: [id], onDelete: SetNull)
  subTenants      Branch[]              @relation("SubTenants")
  manager         User?                 @relation("BranchManager", fields: [managerId], references: [id], onDelete: SetNull)
  userBranches    UserBranch[]
  dailyReports    DailyReport[]
  cashShortages   CashShortage[]
  targets         BranchTarget[]
  healthScores    BranchHealthScore[]
  streak          BranchStreak?
  missingReports  MissingReportReason[]
  rentalsAsHost   BranchRental[]        @relation("RentalHost")
  rentalsAsTenant BranchRental[]        @relation("RentalTenant")
  vehicles        Vehicle[]
  sharedDocuments DocumentSharedBranch[]

  @@unique([orgId, code])
  @@index([orgId, isActive])
  @@index([orgId, businessType])
  @@index([companyId, isActive])
  @@index([parentBranchId])
  @@map("branches")
}

// =============================================================
// 3b. branch_rentals — sub-tenant rental contracts
// Pump (host) ↔ Tenant (7-11 / Café / external shop) — fixed / % / mixed
// =============================================================
enum RentalType {
  fixed_monthly  // ค่าเช่ารายเดือนตายตัว
  percentage     // % ของยอดขายผู้เช่า
  mixed          // ทั้ง fixed + %
}

model BranchRental {
  id              String     @id @default(uuid()) @db.Uuid
  orgId           String     @map("org_id") @db.Uuid
  hostBranchId    String     @map("host_branch_id") @db.Uuid // ปั๊ม
  tenantBranchId  String?    @map("tenant_branch_id") @db.Uuid // ถ้าเป็นร้านในเครือ
  tenantName      String     @map("tenant_name") // ชื่อร้าน (อาจเป็นภายนอก)
  rentalType      RentalType @map("rental_type")
  fixedAmount     Decimal?   @map("fixed_amount") @db.Decimal(15, 2) // ฿/เดือน
  percentageRate  Decimal?   @map("percentage_rate") @db.Decimal(6, 4) // 0.05 = 5%
  startDate       DateTime   @map("start_date") @db.Date
  endDate         DateTime?  @map("end_date") @db.Date
  notes           String?
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  hostBranch   Branch       @relation("RentalHost", fields: [hostBranchId], references: [id], onDelete: Cascade)
  tenantBranch Branch?      @relation("RentalTenant", fields: [tenantBranchId], references: [id], onDelete: SetNull)

  @@index([orgId, isActive])
  @@index([hostBranchId, isActive])
  @@index([tenantBranchId])
  @@map("branch_rentals")
}

// =============================================================
// 4. user_branches — N:M (staff อาจดูแลหลายสาขา)
// =============================================================
model UserBranch {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([orgId])
  @@index([branchId, isActive])
  @@map("user_branches")
}

// =============================================================
// 5. report_templates — Field config 7 ประเภท (JSONB)
// =============================================================
model ReportTemplate {
  id               String       @id @default(uuid()) @db.Uuid
  orgId            String       @map("org_id") @db.Uuid
  businessType     BusinessType @unique @map("business_type")
  hasShifts        Boolean      @default(false) @map("has_shifts")
  shifts           String[]     @default([]) // e.g. ["morning","evening"]
  hasReconcile     Boolean      @default(true) @map("has_reconcile")
  fields           Json // Field definitions array
  reconcileFormula String?      @map("reconcile_formula")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@map("report_templates")
}

// =============================================================
// 6. daily_reports — Universal table for 7 business types
// =============================================================
enum ReportStatus {
  draft
  submitted
  approved
  rejected
}

enum Shift {
  morning
  midday
  evening
  all
}

model DailyReport {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  reportDate DateTime @map("report_date") @db.Date
  shift      Shift    @default(all)

  // Sales (universal — applicable to all types)
  totalSales Decimal  @default(0) @map("total_sales") @db.Decimal(15, 2)
  qty1       Decimal? @db.Decimal(12, 3) // ลิตร / ถัง / แก้ว / Session / ห้อง
  qty1Unit   String?  @map("qty1_unit")
  qty2       Decimal? @db.Decimal(12, 3) // ขนม / น้ำหนักก๊าซ / ยอดอาหาร
  qty2Unit   String?  @map("qty2_unit")

  // Receipts
  cash     Decimal @default(0) @db.Decimal(15, 2)
  transfer Decimal @default(0) @db.Decimal(15, 2)
  card     Decimal @default(0) @db.Decimal(15, 2)
  credit   Decimal @default(0) @db.Decimal(15, 2)
  shortage Decimal @default(0) @db.Decimal(15, 2)

  // Sub-tenant rental income (host branches like fuel stations with 7-11/Café tenants)
  rentalIncome Decimal @default(0) @map("rental_income") @db.Decimal(15, 2)

  // Training center summary (only used by training_center business type)
  trainingSessions Int? @map("training_sessions")

  // Notes
  notes      String?
  isSpike    Boolean @default(false) @map("is_spike")
  isOffHours Boolean @default(false) @map("is_off_hours")

  // Workflow
  status         ReportStatus @default(submitted)
  submittedById  String       @map("submitted_by_id") @db.Uuid
  submittedAt    DateTime     @default(now()) @map("submitted_at") @db.Timestamptz(6)
  approvedById   String?      @map("approved_by_id") @db.Uuid
  approvedAt     DateTime?    @map("approved_at") @db.Timestamptz(6)
  rejectedReason String?      @map("rejected_reason")
  unlockById     String?      @map("unlock_by_id") @db.Uuid
  unlockReason   String?      @map("unlock_reason")
  unlockAt       DateTime?    @map("unlock_at") @db.Timestamptz(6)

  // Telegram tracking
  telegramMessageId String? @map("telegram_message_id")
  telegramChatId    String? @map("telegram_chat_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Restrict)
  branch      Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  submittedBy User           @relation("ReportSubmitter", fields: [submittedById], references: [id], onDelete: Restrict)
  approvedBy  User?          @relation("ReportApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  unlockBy    User?          @relation("ReportUnlocker", fields: [unlockById], references: [id], onDelete: SetNull)
  shortages   CashShortage[]

  @@unique([branchId, reportDate, shift])
  @@index([orgId, reportDate])
  @@index([orgId, status])
  @@index([orgId, status, reportDate])
  @@index([branchId, reportDate])
  @@index([branchId, shift, reportDate])
  @@map("daily_reports")
}

// =============================================================
// 7. cash_shortages — เงินขาด (CASHHUB §13)
// =============================================================
model CashShortage {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  reportId     String   @map("report_id") @db.Uuid
  branchId     String   @map("branch_id") @db.Uuid
  reportDate   DateTime @map("report_date") @db.Date
  amount       Decimal  @db.Decimal(15, 2)
  personId     String?  @map("person_id") @db.Uuid
  personName   String?  @map("person_name") // snapshot
  isIdentified Boolean  @default(false) @map("is_identified")
  note         String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  report DailyReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  person User?        @relation("ShortagePerson", fields: [personId], references: [id], onDelete: SetNull)

  @@index([orgId, reportDate])
  @@index([personId, reportDate])
  @@index([branchId, reportDate])
  @@map("cash_shortages")
}

// =============================================================
// 8. audit_logs — sensitive action trail
// =============================================================
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String // CREATE_REPORT, APPROVE_REPORT, LOGIN, etc.
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id") @db.Uuid
  diff         Json? // {old: {...changed fields}, new: {...changed fields}}
  ipAddress    String?  @map("ip_address") @db.Inet
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([resourceType, resourceId, action, userId, createdAt])
  @@index([orgId, createdAt])
  @@index([orgId, action, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// =============================================================
// 9. notifications — in-app notification inbox (bell icon)
// =============================================================
model Notification {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  type         String // info | warning | danger | success
  module       String? // cashhub | fuelos | docuflow | core
  title        String
  body         String
  link         String?
  isRead       Boolean  @default(false) @map("is_read")
  sentTelegram Boolean  @default(false) @map("sent_telegram")
  sentLine     Boolean  @default(false) @map("sent_line")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([orgId, createdAt])
  @@map("notifications")
}

// =============================================================
// 10. user_sessions — login/device history (My Sessions page)
// =============================================================
model UserSession {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  ipAddress    String?   @map("ip_address") @db.Inet
  userAgent    String?   @map("user_agent")
  device       String? // parsed from UA: "Chrome on macOS"
  loginAt      DateTime  @default(now()) @map("login_at") @db.Timestamptz(6)
  lastActiveAt DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(6)
  logoutAt     DateTime? @map("logout_at") @db.Timestamptz(6)
  isRevoked    Boolean   @default(false) @map("is_revoked")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginAt])
  @@index([orgId, loginAt])
  @@map("user_sessions")
}

// =============================================================
// 11. register_requests — self-register queue
// =============================================================
model RegisterRequest {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String    @map("org_id") @db.Uuid
  name          String
  phone         String
  email         String?
  branchId      String?   @map("branch_id") @db.Uuid
  requestedRole String    @map("requested_role") // staff | branch_manager | driver
  notes         String?
  status        String    @default("pending") // pending | approved | rejected
  reviewedById  String?   @map("reviewed_by_id") @db.Uuid
  reviewedAt    DateTime? @map("reviewed_at") @db.Timestamptz(6)
  rejectReason  String?   @map("reject_reason")
  resultUserId  String?   @map("result_user_id") @db.Uuid
  ipAddress     String?   @map("ip_address") @db.Inet
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  reviewer User?        @relation("RegisterReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([orgId, status, createdAt])
  @@map("register_requests")
}

// =============================================================
// 12. org_modules — toggle CashHub/FuelOS/DocuFlow per org
// =============================================================
model OrgModule {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String    @map("org_id") @db.Uuid
  moduleName    String    @map("module_name") // cashhub | fuelos | docuflow
  isActive      Boolean   @default(true) @map("is_active")
  activatedAt   DateTime  @default(now()) @map("activated_at") @db.Timestamptz(6)
  deactivatedAt DateTime? @map("deactivated_at") @db.Timestamptz(6)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleName])
  @@map("org_modules")
}

// =============================================================
// 12b. user_modules — per-user module access (added 2026-05-07)
// Admin tier (super/org_admin/admin) bypasses this — they see all modules.
// Other roles need an active row here to see CashHub/FuelOS/DocuFlow.
// =============================================================
model UserModule {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  moduleName String   @map("module_name") // cashhub | fuelos | docuflow
  isActive   Boolean  @default(true) @map("is_active")
  grantedBy  String?  @map("granted_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([orgId, userId, moduleName])
  @@index([userId, isActive])
  @@index([orgId, moduleName, isActive])
  @@map("user_modules")
}

// =============================================================
// 13. branch_groups — cluster branches (region/business/custom)
// =============================================================
model BranchGroup {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String // "อีสาน", "ปั๊มทั้งหมด", "เครือ Hotel"
  emoji     String?
  groupType String   @map("group_type") // region | business | custom
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org     Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members BranchGroupMember[]

  @@index([orgId, groupType])
  @@map("branch_groups")
}

model BranchGroupMember {
  id       String @id @default(uuid()) @db.Uuid
  groupId  String @map("group_id") @db.Uuid
  branchId String @map("branch_id") @db.Uuid

  group BranchGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, branchId])
  @@index([branchId])
  @@map("branch_group_members")
}

// =============================================================
// 14. holidays — per-org calendar (skip report deadlines)
// =============================================================
model Holiday {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  date      DateTime @db.Date
  name      String // "วันสงกรานต์", "วันหยุดสาขา"
  isOrgWide Boolean  @default(true) @map("is_org_wide")
  branchIds String[] @default([]) @db.Uuid // empty = all branches when isOrgWide
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, date])
  @@map("holidays")
}

// =============================================================
// 15. telegram_subscriptions — user ↔ bot pairing per bot
// =============================================================
model TelegramSubscription {
  id       String   @id @default(uuid()) @db.Uuid
  orgId    String   @map("org_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  botName  String   @map("bot_name") // pooilgroup | pooilcash | pooilfuel | pooildoc
  chatId   String   @map("chat_id")
  username String?
  isActive Boolean  @default(true) @map("is_active")
  linkedAt DateTime @default(now()) @map("linked_at") @db.Timestamptz(6)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, botName])
  @@index([orgId, botName, isActive])
  @@map("telegram_subscriptions")
}

// =============================================================
// 16. telegram_groups — group routing per module
// =============================================================
model TelegramGroup {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  botName   String   @map("bot_name")
  chatId    String   @unique @map("chat_id") // negative number for groups
  name      String // "Pooilgroup CashHub - Northeast"
  module    String // cashhub | fuelos | docuflow | core
  scope     Json     @default("{}") // {region, branchIds, businessTypes}
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, module, isActive])
  @@map("telegram_groups")
}

// =============================================================
// 17. telegram_pairing_tokens — /start <token> flow
// =============================================================
model TelegramPairingToken {
  id        String    @id @default(uuid()) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique
  botName   String?   @map("bot_name") // null = pair to all bots
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, usedAt])
  @@map("telegram_pairing_tokens")
}

// =============================================================
// 18. branch_targets — monthly sales target per branch
// =============================================================
model BranchTarget {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  year       Int
  month      Int // 1-12
  amount     Decimal  @db.Decimal(15, 2)
  source     String   @default("manual") // manual | derived_prev_year | derived_avg_3m
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, year, month])
  @@index([orgId, year, month])
  @@map("branch_targets")
}

// =============================================================
// 19. branch_health_scores — A-F grade computed daily by cron
// =============================================================
model BranchHealthScore {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  computedFor DateTime @map("computed_for") @db.Date
  score       Int // 0-100
  grade       String // A | B | C | D | E | F
  breakdown   Json // {fillRate, onTime, reconcileOk, salesGrowth, targetReached, ...}
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, computedFor])
  @@index([orgId, computedFor])
  @@index([branchId, computedFor])
  @@map("branch_health_scores")
}

// =============================================================
// 20. branch_streaks — current/longest fill streak (gamification)
// =============================================================
model BranchStreak {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  branchId        String    @unique @map("branch_id") @db.Uuid
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  lastReportDate  DateTime? @map("last_report_date") @db.Date
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("branch_streaks")
}

// =============================================================
// 21. missing_report_reasons — why a day was not filled
// =============================================================
model MissingReportReason {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  reportDate  DateTime @map("report_date") @db.Date
  reasonType  String   @map("reason_type") // sick | holiday | system | waiting | other
  reasonText  String?  @map("reason_text")
  reportedBy  String?  @map("reported_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, reportDate])
  @@index([orgId, reportDate])
  @@map("missing_report_reasons")
}

// =============================================================
// 22. documents — DocuFlow main table
// Spec: ดีเทลv1/DOCUFLOW.md · ~1,100 docs across group/company/biz/branch/person
// =============================================================
model Document {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  name            String
  description     String?
  fileKey         String   @map("file_key") // R2 object key
  filePublicUrl   String?  @map("file_public_url")
  mimeType        String?  @map("mime_type")
  fileSize        Int?     @map("file_size") // bytes
  uploadedById    String?  @map("uploaded_by_id") @db.Uuid
  uploadedAt      DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org            Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  uploadedBy     User?                  @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  ownership      DocumentOwnership[]
  tags           DocumentTag[]
  renewals       DocumentRenewal[]
  sharedBranches DocumentSharedBranch[]
  vehicleDocs    VehicleDocument[]
  personDocs     PersonDocument[]
  signaturePlacements DocumentSignaturePlacement[]
  analyses       DocumentAnalysis[]

  @@index([orgId, isActive])
  @@index([orgId, uploadedAt])
  @@map("documents")
}

// =============================================================
// 23. document_ownership — 4-level (group/company/business_type/branch/person)
// =============================================================
model DocumentOwnership {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  documentId   String   @map("document_id") @db.Uuid
  level        String // group | company | business_type | branch | person
  companyId    String?  @map("company_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  personId     String?  @map("person_id") @db.Uuid
  businessType String?  @map("business_type")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  document Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([orgId, level])
  @@index([documentId])
  @@index([branchId])
  @@map("document_ownership")
}

// =============================================================
// 24. document_tags — Tag system (cross-cutting categorization)
// =============================================================
model DocumentTag {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  tag        String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  document Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, tag])
  @@index([orgId, tag])
  @@map("document_tags")
}

// =============================================================
// 25. document_renewals — expiry tracking + renewal workflow
// =============================================================
model DocumentRenewal {
  id                  String    @id @default(uuid()) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  documentId          String    @map("document_id") @db.Uuid
  expiryDate          DateTime  @map("expiry_date") @db.Date
  renewalPeriodYears  Int?      @map("renewal_period_years")
  alertDays           Int[]     @default([90, 30, 7]) @map("alert_days")
  responsibleUserId   String?   @map("responsible_user_id") @db.Uuid
  status              String    @default("pending") // pending | in_progress | renewed | overdue
  lastRenewedDate     DateTime? @map("last_renewed_date") @db.Date
  nextRenewalDate     DateTime? @map("next_renewal_date") @db.Date
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  document        Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  responsibleUser User?        @relation("RenewalResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)

  @@index([orgId, expiryDate])
  @@index([orgId, status])
  @@map("document_renewals")
}

// =============================================================
// 26. document_shared_branches — เอกสารใช้ร่วมกันหลายสาขา
// =============================================================
model DocumentSharedBranch {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz(6)

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  document Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  branch   Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([documentId, branchId])
  @@index([orgId])
  @@index([branchId])
  @@map("document_shared_branches")
}

// =============================================================
// 27. vehicles — fleet (~100 คัน · shared with FuelOS in Phase 2)
// Stored under lib/vehicles/ generic loader — DocuFlow + FuelOS reuse
// =============================================================
model Vehicle {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  licensePlate String   @map("license_plate")
  vehicleType  String   @map("vehicle_type") // fuel_truck | gas_truck | service | personal | other
  companyId    String?  @map("company_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid // home base
  isActive     Boolean  @default(true) @map("is_active")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org       Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company   Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  branch    Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  documents VehicleDocument[]

