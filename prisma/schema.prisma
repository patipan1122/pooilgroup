  // fieldSchema = { version: 1, sections: [{ title, fields: [...] }] }
  fieldSchema Json                 @default("{\"version\":1,\"sections\":[]}") @map("field_schema")
  // settings = { closingDateAutoClose, notifyTemplates, ... }
  settings    Json                 @default("{}")
