  maker    ChairopsUser  @relation("chairops_writeoffs_maker", fields: [makerId], references: [id])
  approver ChairopsUser? @relation("chairops_writeoffs_approver", fields: [approverId], references: [id])

  @@index([orgId])
  @@index([branchId, status])
  @@schema("chairops")
}

model ChairopsDamageTicket {
