// Pooilgroup ERP — Prisma Schema
// 1 organization "Pooilgroup" → 2 companies (Pooil Oil + JP Sync Group) → 118 branches across 11 business types
// See plan: /Users/patipantantikul/.claude/plans/sunny-splashing-cocoa.md
// Spec source: /Users/patipantantikul/Desktop/pooilgroup/ดีเทลv1/CORE_SYSTEM.md + CASHHUB.md

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "chairops", "playland"]
}

// =============================================================
// 1. organizations — multi-tenant root
// =============================================================
model Organization {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  slug           String   @unique
  logoUrl        String?  @map("logo_url")
  settings       Json     @default("{}")
  lineOaId       String?  @map("line_oa_id")
  telegramChatId String?  @map("telegram_chat_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users                   User[]
  companies               Company[]
  branches                Branch[]
  branchRentals           BranchRental[]
  reportTemplates         ReportTemplate[]
  dailyReports            DailyReport[]
  reportDrafts            ReportDraft[]
  bugReports              BugReport[]
  cashShortages           CashShortage[]
  auditLogs               AuditLog[]
  userBranches            UserBranch[]
  notifications           Notification[]
  userSessions            UserSession[]
  registerRequests        RegisterRequest[]
  orgModules              OrgModule[]
  branchGroups            BranchGroup[]
  holidays                Holiday[]
  telegramSubs            TelegramSubscription[]
  telegramGroups          TelegramGroup[]
  telegramTokens          TelegramPairingToken[]
  branchTargets           BranchTarget[]
  branchHealthScores      BranchHealthScore[]
  branchStreaks           BranchStreak[]
  missingReports          MissingReportReason[]
  documents               Document[]
  documentOwnerships      DocumentOwnership[]
  documentTags            DocumentTag[]
  documentRenewals        DocumentRenewal[]
  documentSharedBranches  DocumentSharedBranch[]
  vehicles                Vehicle[]
  vehicleDocuments        VehicleDocument[]
  personDocuments         PersonDocument[]
  signaturePlacements     DocumentSignaturePlacement[]
  documentAnalyses        DocumentAnalysis[]
  aiSearchCache           AiSearchCache[]
  // FuelOS Sprint 6
  depotPrices             DepotPrice[]
  zoneMargins             ZoneMargin[]
  contacts                Contact[]
  customerEntities        CustomerEntity[]
  deliveryLocations       DeliveryLocation[]
  customerQuotes          CustomerQuote[]
  priceAlertLogs          PriceAlertLog[]
  lineResponseLogs        LineResponseLog[]
  fuelOrders              FuelOrder[]
  trucks                  Truck[]
  driverProfiles          DriverProfile[]
  driverLocations         DriverLocation[]
  payments                Payment[]
  flashSales              FlashSale[]
  creditDocuments         CreditDocument[]
  chequeTrackings         ChequeTracking[]
  // Recruit module
  recruitPostings         RecruitJobPosting[]
  recruitApplicants       RecruitApplicant[]
  recruitApplications     RecruitApplication[]
  recruitApplicationNotes RecruitApplicationNote[]
  recruitBlacklist        RecruitBlacklist[]
  recruitInterviews       RecruitInterview[]
  recruitMessages         RecruitMessage[]
  recruitRules            RecruitScreeningRule[]
  recruitFormTemplates    RecruitFormTemplate[]
  recruitInboxChannels    RecruitInboxChannel[]
  recruitReferrals        RecruitReferral[]
  recruitErasureRequests  RecruitErasureRequest[]
  // Repair module
  repairCategories        RepairCategory[]
  repairTickets           RepairTicket[]
  repairTechnicians       RepairTechnician[]
  repairPhotos            RepairPhoto[]
  repairParts             RepairPart[]
  repairTimelineEvents    RepairTimelineEvent[]
  repairVendorTokens      RepairVendorToken[]
  // ClawFleet module
  cfMachines              CfMachine[]
  cfMachineGroups         CfMachineGroup[]
  cfProducts              CfProduct[]
  cfMachineLoadouts       CfMachineLoadout[]
  cfExchangerLoadouts     CfExchangerLoadout[]
  cfCollectionSessions    CfCollectionSession[]
  cfCollectionEvents      CfCollectionEvent[]
  cfStockMovements        CfStockMovement[]
  cfDeliveries            CfDelivery[]

  @@map("organizations")
  @@schema("public")
}

// =============================================================
// 1b. companies — legal entity layer under one Pooilgroup org
// e.g. "Pooil Oil" + "JP Sync Group" (separate VAT, separate accounting)
// Branches attach to a company; users belong to org and may span companies
// =============================================================
model Company {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  code       String // POOIL | JPSYNC
  name       String // "Pooil Oil" | "JP Sync Group"
  taxId      String?  @map("tax_id") // เลขผู้เสียภาษี
  address    String?
  phone      String?
  logoUrl    String?  @map("logo_url")
  brandColor String?  @map("brand_color") // optional override per company
  settings   Json     @default("{}")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org             Organization        @relation(fields: [orgId], references: [id], onDelete: Restrict)
  branches        Branch[]
  vehicles        Vehicle[]
  recruitPostings RecruitJobPosting[]
  repairTickets   RepairTicket[]

  @@unique([orgId, code])
  @@index([orgId, isActive])
  @@map("companies")
  @@schema("public")
}

// =============================================================
// 2. users — auth + RBAC
// =============================================================
enum UserRole {
  super_admin // Owner — strategic + financial + identity
  admin // Operational admin — runs day-to-day
  area_manager // Manages multiple branches in a region/business
  branch_manager // 1-2 per branch
  staff // Submits reports / works on branch
  driver // FuelOS Phase 2
  viewer // Read-only (accountant / HR)
  program_admin // Admin of specific program(s) only — scoped via user_modules · NOT org-wide
  org_admin // [deprecated alias — kept for back-compat, will migrate to admin]

  @@schema("public")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  employeeCode        String?   @map("employee_code") // referenced from Humansoft HR app
  email               String?   @unique
  name                String
  phone               String?
  passwordHash        String?   @map("password_hash")
  role                UserRole
  lineUserId          String?   @unique @map("line_user_id")
  telegramUserId      String?   @map("telegram_user_id")
  telegramChatId      String?   @map("telegram_chat_id")
  mustChangePassword  Boolean   @default(true) @map("must_change_password")
  isActive            Boolean   @default(true) @map("is_active")
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz(6)
  failedLoginCount    Int       @default(0) @map("failed_login_count")
  lockedUntil         DateTime? @map("locked_until") @db.Timestamptz(6)
  invitedBy           String?   @map("invited_by") @db.Uuid
  inviteToken         String?   @unique @map("invite_token")
  inviteExpiresAt     DateTime? @map("invite_expires_at") @db.Timestamptz(6)
  inviteUsedAt        DateTime? @map("invite_used_at") @db.Timestamptz(6)
  // Optional auto-expiry for non-permanent users (auditors, contractors,
  // temp staff). When set + `now() > tempAccessExpiresAt`, the access-review
  // cron deactivates the account. NULL = permanent until manual deactivation.
  // Spec: ดีเทลv1/CORE_SYSTEM.md §2.6 Temporary Access.
  tempAccessExpiresAt DateTime? @map("temp_access_expires_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org                      Organization                 @relation(fields: [orgId], references: [id], onDelete: Restrict)
  userBranches             UserBranch[]
  managedBranches          Branch[]                     @relation("BranchManager")
  submittedReports         DailyReport[]                @relation("ReportSubmitter")
  approvedReports          DailyReport[]                @relation("ReportApprover")
  reportDrafts             ReportDraft[]
  reportedBugs             BugReport[]                  @relation("BugReporter")
  acknowledgedBugs         BugReport[]                  @relation("BugAcknowledger")
  unlockedReports          DailyReport[]                @relation("ReportUnlocker")
  shortagesAttributed      CashShortage[]               @relation("ShortagePerson")
  auditLogs                AuditLog[]
  notifications            Notification[]
  sessions                 UserSession[]
  reviewedRequests         RegisterRequest[]            @relation("RegisterReviewer")
  telegramSubs             TelegramSubscription[]
  telegramTokens           TelegramPairingToken[]
  uploadedDocuments        Document[]                   @relation("DocumentUploader")
  responsibleRenewals      DocumentRenewal[]            @relation("RenewalResponsible")
  personDocuments          PersonDocument[]
  signaturePlacements      DocumentSignaturePlacement[] @relation("SignaturePlacementSigner")
  // FuelOS Sprint 6
  depotPricesEntered       DepotPrice[]                 @relation("DepotPriceEntered")
  assignedContacts         Contact[]                    @relation("ContactSales")
  quotesAsSales            CustomerQuote[]              @relation("QuoteSales")
  priceAlertsSent          PriceAlertLog[]              @relation("PriceAlertSales")
  lineResponsesAsSales     LineResponseLog[]            @relation("LineResponseSales")
  fuelOrdersAsSales        FuelOrder[]                  @relation("FuelOrderSales")
  driverProfile            DriverProfile?
  paymentsCreated          Payment[]                    @relation("PaymentCreatedBy")
  flashSalesCreated        FlashSale[]                  @relation("FlashSaleCreatedBy")
  // Recruit module
  recruitPostingsCreated   RecruitJobPosting[]          @relation("RecruitPostingCreator")
  recruitNotesAuthored     RecruitApplicationNote[]     @relation("RecruitNoteAuthor")
  recruitBlacklistAdded    RecruitBlacklist[]           @relation("RecruitBlacklistAdder")
  recruitBlacklistRemoved  RecruitBlacklist[]           @relation("RecruitBlacklistRemover")
  recruitInterviewsCreated RecruitInterview[]           @relation("RecruitInterviewCreator")
  recruitMessagesSent      RecruitMessage[]             @relation("RecruitMessageSender")
  recruitRulesCreated      RecruitScreeningRule[]       @relation("RecruitRuleCreator")
  recruitFormTemplates     RecruitFormTemplate[]        @relation("RecruitFormTemplateCreator")
  recruitInboxChannels     RecruitInboxChannel[]        @relation("RecruitInboxChannelCreator")
  recruitReferralsAsRef    RecruitReferral[]            @relation("RecruitReferrerUser")
  recruitErasureDecided    RecruitErasureRequest[]      @relation("RecruitErasureDecider")
  // Repair module
  repairTicketsReported    RepairTicket[]               @relation("RepairTicketReporter")
  repairTicketsResolved    RepairTicket[]               @relation("RepairTicketResolver")
  repairTicketsClosed      RepairTicket[]               @relation("RepairTicketCloser")
  repairTechnicianLink     RepairTechnician?
  repairTimelineEvents     RepairTimelineEvent[]        @relation("RepairTimelineActor")
  repairPhotosUploaded     RepairPhoto[]                @relation("RepairPhotoUploader")
  repairPartsAdded         RepairPart[]                 @relation("RepairPartAddedBy")
  repairPartsOrdered       RepairPart[]                 @relation("RepairPartOrderedBy")
  // ClawFleet module
  cfSessionsOpened         CfCollectionSession[]        @relation("CfSessionOpener")
  cfSessionsClosed         CfCollectionSession[]        @relation("CfSessionCloser")
  cfSessionsReviewed       CfCollectionSession[]        @relation("CfSessionReviewer")
  cfEventsCollected        CfCollectionEvent[]          @relation("CfEventCollector")
  cfStockMovementsCreated  CfStockMovement[]            @relation("CfStockCreator")
  cfDeliveriesCreated      CfDelivery[]                 @relation("CfDeliveryCreator")

  @@unique([orgId, employeeCode])
  @@index([orgId, isActive])
  @@index([orgId, role])
  @@index([lineUserId])
  @@map("users")
  @@schema("public")
}

// =============================================================
// 3. branches — 30+ สาขา / 7 business types
// =============================================================
enum BusinessType {
  fuel_station // ปั๊มน้ำมัน
  lpg_station // ปั๊มแก๊ส (เติมรถ)
  lpg_retail // ร้านค้าแก๊ส (ขายถัง)
  bottling_plant // โรงบรรจุก๊าซ
  hotel // โรงแรม
  convenience_store // 7-Eleven
  ev_station // EV Station
  cafe // Café Amazon
  cafe_punthai // ร้านกาแฟพันธุ์ไทย
  massage_chair // เก้าอี้นวด (kiosk)
  claw_machine // ตู้คีบ (kiosk)
  training_center // ศูนย์ฝึกอบรม
  transport // FuelOS Phase 2
  gas_fleet // FuelOS Phase 2

  @@schema("public")
}

model Branch {
  id             String       @id @default(uuid()) @db.Uuid
  orgId          String       @map("org_id") @db.Uuid
  companyId      String       @map("company_id") @db.Uuid // Pooil Oil or JP Sync
  parentBranchId String?      @map("parent_branch_id") @db.Uuid // host branch for sub-tenants (e.g. 7-11 inside a fuel station)
  code           String
  name           String
  businessType   BusinessType @map("business_type")
  province       String?
  region         String?
  address        String?
  lat            Decimal?     @db.Decimal(10, 7)
  lng            Decimal?     @db.Decimal(10, 7)
  managerId      String?      @map("manager_id") @db.Uuid
  phone          String?
  lineGroupId    String?      @map("line_group_id")
  reportDeadline String       @default("21:00") @map("report_deadline") // HH:mm string for simplicity
  settings       Json         @default("{}")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  org              Organization           @relation(fields: [orgId], references: [id], onDelete: Restrict)
  company          Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  parentBranch     Branch?                @relation("SubTenants", fields: [parentBranchId], references: [id], onDelete: SetNull)
  subTenants       Branch[]               @relation("SubTenants")
  manager          User?                  @relation("BranchManager", fields: [managerId], references: [id], onDelete: SetNull)
  userBranches     UserBranch[]
  dailyReports     DailyReport[]
  reportDrafts     ReportDraft[]
  cashShortages    CashShortage[]
  targets          BranchTarget[]
  healthScores     BranchHealthScore[]
  streak           BranchStreak?
  missingReports   MissingReportReason[]
  rentalsAsHost    BranchRental[]         @relation("RentalHost")
  rentalsAsTenant  BranchRental[]         @relation("RentalTenant")
  vehicles         Vehicle[]
  sharedDocuments  DocumentSharedBranch[]
  repairTickets    RepairTicket[]
  // ClawFleet
  cfMachines       CfMachine[]
  cfMachineGroups  CfMachineGroup[]
  cfStockMovements CfStockMovement[]
  cfSessions       CfCollectionSession[]
  cfDeliveries     CfDelivery[]

  @@unique([orgId, code])
  @@index([orgId, isActive])
  @@index([orgId, businessType])
  @@index([companyId, isActive])
  @@index([parentBranchId])
  @@map("branches")
  @@schema("public")
}

// =============================================================
// 3b. branch_rentals — sub-tenant rental contracts
// Pump (host) ↔ Tenant (7-11 / Café / external shop) — fixed / % / mixed
// =============================================================
enum RentalType {
  fixed_monthly // ค่าเช่ารายเดือนตายตัว
  percentage // % ของยอดขายผู้เช่า
  mixed // ทั้ง fixed + %

  @@schema("public")
}

model BranchRental {
  id             String     @id @default(uuid()) @db.Uuid
  orgId          String     @map("org_id") @db.Uuid
  hostBranchId   String     @map("host_branch_id") @db.Uuid // ปั๊ม
  tenantBranchId String?    @map("tenant_branch_id") @db.Uuid // ถ้าเป็นร้านในเครือ
  tenantName     String     @map("tenant_name") // ชื่อร้าน (อาจเป็นภายนอก)
  rentalType     RentalType @map("rental_type")
  fixedAmount    Decimal?   @map("fixed_amount") @db.Decimal(15, 2) // ฿/เดือน
  percentageRate Decimal?   @map("percentage_rate") @db.Decimal(6, 4) // 0.05 = 5%
  startDate      DateTime   @map("start_date") @db.Date
  endDate        DateTime?  @map("end_date") @db.Date
  notes          String?
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  hostBranch   Branch       @relation("RentalHost", fields: [hostBranchId], references: [id], onDelete: Cascade)
  tenantBranch Branch?      @relation("RentalTenant", fields: [tenantBranchId], references: [id], onDelete: SetNull)

  @@index([orgId, isActive])
  @@index([hostBranchId, isActive])
  @@index([tenantBranchId])
  @@map("branch_rentals")
  @@schema("public")
}

// =============================================================
// 4. user_branches — N:M (staff อาจดูแลหลายสาขา)
// =============================================================
model UserBranch {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([orgId])
  @@index([branchId, isActive])
  @@map("user_branches")
  @@schema("public")
}

// =============================================================
// 5. report_templates — Field config 7 ประเภท (JSONB)
// =============================================================
model ReportTemplate {
  id               String       @id @default(uuid()) @db.Uuid
  orgId            String       @map("org_id") @db.Uuid
  businessType     BusinessType @unique @map("business_type")
  hasShifts        Boolean      @default(false) @map("has_shifts")
  shifts           String[]     @default([]) // e.g. ["morning","evening"]
  hasReconcile     Boolean      @default(true) @map("has_reconcile")
  fields           Json // Field definitions array
  reconcileFormula String?      @map("reconcile_formula")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@index([orgId])
  @@map("report_templates")
  @@schema("public")
}

// =============================================================
// 6. daily_reports — Universal table for 7 business types
// =============================================================
enum ReportStatus {
  draft
  submitted
  approved
  rejected

  @@schema("public")
}

enum Shift {
  morning
  midday
  evening
  all

  @@schema("public")
}

model DailyReport {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  reportDate DateTime @map("report_date") @db.Date
  shift      Shift    @default(all)

  // Sales (universal — applicable to all types)
  totalSales Decimal  @default(0) @map("total_sales") @db.Decimal(15, 2)
  qty1       Decimal? @db.Decimal(12, 3) // ลิตร / ถัง / แก้ว / Session / ห้อง
  qty1Unit   String?  @map("qty1_unit")
  qty2       Decimal? @db.Decimal(12, 3) // ขนม / น้ำหนักก๊าซ / ยอดอาหาร
  qty2Unit   String?  @map("qty2_unit")

  // Receipts
  cash     Decimal @default(0) @db.Decimal(15, 2)
  transfer Decimal @default(0) @db.Decimal(15, 2)
  card     Decimal @default(0) @db.Decimal(15, 2)
  credit   Decimal @default(0) @db.Decimal(15, 2)
  shortage Decimal @default(0) @db.Decimal(15, 2)

  // Sub-tenant rental income (host branches like fuel stations with 7-11/Café tenants)
  rentalIncome Decimal @default(0) @map("rental_income") @db.Decimal(15, 2)

  // Training center summary (only used by training_center business type)
  trainingSessions Int? @map("training_sessions")

  // Notes
  notes      String?
  isSpike    Boolean @default(false) @map("is_spike")
  isOffHours Boolean @default(false) @map("is_off_hours")

  // Workflow
  status         ReportStatus @default(submitted)
  submittedById  String       @map("submitted_by_id") @db.Uuid
  submittedAt    DateTime     @default(now()) @map("submitted_at") @db.Timestamptz(6)
  approvedById   String?      @map("approved_by_id") @db.Uuid
  approvedAt     DateTime?    @map("approved_at") @db.Timestamptz(6)
  rejectedReason String?      @map("rejected_reason")
  unlockById     String?      @map("unlock_by_id") @db.Uuid
  unlockReason   String?      @map("unlock_reason")
  unlockAt       DateTime?    @map("unlock_at") @db.Timestamptz(6)

  // Telegram tracking
  telegramMessageId String? @map("telegram_message_id")
  telegramChatId    String? @map("telegram_chat_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Restrict)
  branch      Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  submittedBy User           @relation("ReportSubmitter", fields: [submittedById], references: [id], onDelete: Restrict)
  approvedBy  User?          @relation("ReportApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  unlockBy    User?          @relation("ReportUnlocker", fields: [unlockById], references: [id], onDelete: SetNull)
  shortages   CashShortage[]

  @@unique([branchId, reportDate, shift])
  @@index([orgId, reportDate])
  @@index([orgId, status])
  @@index([orgId, status, reportDate])
  @@index([branchId, reportDate])
  @@index([branchId, shift, reportDate])
  @@map("daily_reports")
  @@schema("public")
}

// =============================================================
// 6b. report_drafts — autosave in-progress form (server-side, replaces localStorage)
// 2026-05-20 (Branch Manager audit): localStorage หายเมื่อเปลี่ยนเครื่อง
// → ย้ายเข้า DB · auto-delete หลัง submit สำเร็จ
// Unique per (user, branch, date, shift) — 1 draft ต่อบริบทเดียว
// =============================================================
model ReportDraft {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  branchId   String   @map("branch_id") @db.Uuid
  reportDate DateTime @map("report_date") @db.Date
  shift      String   @default("all")
  formValues Json     @map("form_values")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId, reportDate, shift])
  @@index([orgId, userId])
  @@index([branchId, reportDate])
  @@map("report_drafts")
  @@schema("public")
}

// =============================================================
// 6c. bug_reports — in-app bug report (button hidden under AI floating)
// 2026-05-20: CEO requested · พนักงานคนไหนเจอ bug บนหน้าไหน
// → กดปุ่มแจ้ง + แนบ screenshot · admin ดูที่ /bugs · Claude session ใหม่
// อ่านได้เพื่อ batch-fix
// =============================================================
enum BugStatus {
  new
  acked
  fixed
  closed

  @@schema("public")
}

model BugReport {
  id               String    @id @default(uuid()) @db.Uuid
  orgId            String    @map("org_id") @db.Uuid
  reporterId       String    @map("reporter_id") @db.Uuid
  url              String // window.location.pathname + search ตอน report
  description      String    @db.Text
  screenshotKey    String?   @map("screenshot_key") // R2 object key (null = no screenshot)
  userAgent        String?   @map("user_agent")
  status           BugStatus @default(new)
  adminNote        String?   @map("admin_note") @db.Text
  acknowledgedById String?   @map("acknowledged_by_id") @db.Uuid
  acknowledgedAt   DateTime? @map("acknowledged_at") @db.Timestamptz(6)
  fixedAt          DateTime? @map("fixed_at") @db.Timestamptz(6)
  fixedCommitSha   String?   @map("fixed_commit_sha")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reporter       User         @relation("BugReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  acknowledgedBy User?        @relation("BugAcknowledger", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([orgId, status, createdAt])
  @@index([reporterId, createdAt])
  @@map("bug_reports")
  @@schema("public")
}

// =============================================================
