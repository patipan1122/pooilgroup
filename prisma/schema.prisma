// ---------- 12. Promos ----------
model PlaylandPromo {
  id              String            @id @default(uuid()) @db.Uuid
  orgId           String            @map("org_id") @db.Uuid
  branchId        String?           @map("branch_id") @db.Uuid // null = all branches
  type            PlaylandPromoType
  code            String? // for COUPON
  name            String
  description     String?
  discountPercent Int?              @map("discount_percent") // 0-100
