  files            Json                     @default("[]") // [{key, name, size, mime, uploadedAt}]
  status           RecruitApplicationStatus @default(NEW)
  aiScore          Int?                     @map("ai_score") // 0-100 · null = not yet evaluated
  aiSummary        String?                  @map("ai_summary")
  aiStrengths      Json?                    @map("ai_strengths") // ["...", "...", "..."]
  aiRisks          Json?                    @map("ai_risks")
  aiEvaluatedAt    DateTime?                @map("ai_evaluated_at") @db.Timestamptz(6)
  flaggedBlacklist Boolean                  @default(false) @map("flagged_blacklist")
  blacklistReason  String?                  @map("blacklist_reason")
  starRating       Int?                     @map("star_rating") // 1-5 from HR
  tags             String[]                 @default([])
  source           String? // utm_source from public link
  draft            Boolean                  @default(false) // draft saved by applicant
  submittedAt      DateTime?                @map("submitted_at") @db.Timestamptz(6)
  schemaVersion    Int                      @default(1) @map("schema_version") // snapshot of posting.fieldSchema version
