// =============================================================
// 22. documents — DocuFlow main table
// Spec: ดีเทลv1/DOCUFLOW.md · ~1,100 docs across group/company/biz/branch/person
// =============================================================
model Document {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  name          String
  description   String?
  /// Canonical document type — links Document to lib/docuflow/canonical-docs.ts (e.g. "ใบอนุญาตสถานีบริการน้ำมัน").
  /// Nullable for back-compat; new uploads via smart wizard set this. Phase-2 IA recommendation 2026-05-10.
  documentType  String?  @map("document_type")
  fileKey       String   @map("file_key") // R2 object key
  filePublicUrl String?  @map("file_public_url")
  mimeType      String?  @map("mime_type")
  fileSize      Int?     @map("file_size") // bytes
  uploadedById  String?  @map("uploaded_by_id") @db.Uuid
  uploadedAt    DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org                 Organization                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  uploadedBy          User?                        @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  ownership           DocumentOwnership[]
  tags                DocumentTag[]
  renewals            DocumentRenewal[]
  sharedBranches      DocumentSharedBranch[]
  vehicleDocs         VehicleDocument[]
  personDocs          PersonDocument[]
  signaturePlacements DocumentSignaturePlacement[]
  analyses            DocumentAnalysis[]

  @@index([orgId, isActive])
  @@index([orgId, uploadedAt])
  @@index([orgId, documentType])
  @@map("documents")
  @@schema("public")
}

// =============================================================
