  requestedAt  DateTime             @default(now()) @map("requested_at") @db.Timestamptz(6)
  decidedAt    DateTime?            @map("decided_at") @db.Timestamptz(6)
  decidedById  String?              @map("decided_by_id") @db.Uuid
  decisionNote String?              @map("decision_note")

  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applicant RecruitApplicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  decidedBy User?            @relation("RecruitErasureDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([applicantId])
  @@map("recruit_erasure_requests")
  @@schema("public")
}

// =============================================================
// REPAIR MODULE — ระบบแจ้งซ่อม
// 7 tables · ใครก็แจ้งได้ · admin assign + dispatch · tech see own jobs ·
// purchasing sees parts queue · timeline + photos · tracking via code+phone.
// =============================================================

enum RepairTicketStatus {
  NEW
  ACK
  IN_PROGRESS
  WAITING_PARTS
  RESOLVED
  CLOSED
  CANCELLED

  @@schema("public")
}

enum RepairUrgency {
  URGENT
  NORMAL
  LOW

  @@schema("public")
}

enum RepairReportSource {
  GUIDED
  FREEFORM
  INTERNAL

  @@schema("public")
}

enum RepairPhotoPhase {
  BEFORE
  DURING
  AFTER
  PART
  RECEIPT

  @@schema("public")
}

enum RepairTechnicianKind {
  INTERNAL
  VENDOR

  @@schema("public")
}

enum RepairPartStatus {
  NEEDED
  ORDERED
  DELIVERED
  INSTALLED
  CANCELLED

  @@schema("public")
}

enum RepairEventKind {
  CREATED
  STATUS_CHANGE
  ASSIGN
  UNASSIGN
  COMMENT
  PART_ADDED
  PART_UPDATED
  PHOTO_ADDED
  REOPEN
  CLOSE
  ETA_SET

  @@schema("public")
}

model RepairCategory {
  id             String        @id @default(uuid()) @db.Uuid
  orgId          String        @map("org_id") @db.Uuid
  slug           String
  label          String
  emoji          String?
  defaultUrgency RepairUrgency @default(NORMAL) @map("default_urgency")
  sortOrder      Int           @default(0) @map("sort_order")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tickets RepairTicket[]

  @@unique([orgId, slug])
  @@index([orgId, isActive, sortOrder])
  @@map("repair_categories")
  @@schema("public")
}

model RepairTechnician {
  id          String               @id @default(uuid()) @db.Uuid
  orgId       String               @map("org_id") @db.Uuid
  kind        RepairTechnicianKind
  userId      String?              @unique @map("user_id") @db.Uuid
  name        String
  phone       String?
  lineId      String?              @map("line_id")
  specialties String[]             @default([])
  isActive    Boolean              @default(true) @map("is_active")
  notes       String?
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  org          Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  tickets      RepairTicket[]
  vendorTokens RepairVendorToken[]

  @@index([orgId, kind, isActive])
  @@index([orgId, phone])
  @@map("repair_technicians")
  @@schema("public")
}

model RepairTicket {
  id             String             @id @default(uuid()) @db.Uuid
  orgId          String             @map("org_id") @db.Uuid
  companyId      String?            @map("company_id") @db.Uuid
  branchId       String?            @map("branch_id") @db.Uuid
  categoryId     String?            @map("category_id") @db.Uuid
  ticketCode     String             @unique @map("ticket_code")
  title          String
  description    String             @default("")
  customerImpact String?            @map("customer_impact")
  status         RepairTicketStatus @default(NEW)
  urgency        RepairUrgency      @default(NORMAL)
  source         RepairReportSource @default(FREEFORM)
  reporterName   String             @map("reporter_name")
  reporterPhone  String             @map("reporter_phone")
  reporterEmail  String?            @map("reporter_email")
  reporterUserId String?            @map("reporter_user_id") @db.Uuid
  assignedTechId String?            @map("assigned_tech_id") @db.Uuid
  assignedAt     DateTime?          @map("assigned_at") @db.Timestamptz(6)
  responseDueAt  DateTime?          @map("response_due_at") @db.Timestamptz(6)
  resolveDueAt   DateTime?          @map("resolve_due_at") @db.Timestamptz(6)
  etaAt          DateTime?          @map("eta_at") @db.Timestamptz(6)
  acknowledgedAt DateTime?          @map("acknowledged_at") @db.Timestamptz(6)
  startedAt      DateTime?          @map("started_at") @db.Timestamptz(6)
  resolvedAt     DateTime?          @map("resolved_at") @db.Timestamptz(6)
  resolvedById   String?            @map("resolved_by_id") @db.Uuid
  closedAt       DateTime?          @map("closed_at") @db.Timestamptz(6)
  closedById     String?            @map("closed_by_id") @db.Uuid
  cancelledAt    DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  partsCostCents Int                @default(0) @map("parts_cost_cents")
  laborCostCents Int                @default(0) @map("labor_cost_cents")
  ipAddress      String?            @map("ip_address")
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  org          Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company      Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  branch       Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  category     RepairCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reporterUser User?                 @relation("RepairTicketReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  assignedTech RepairTechnician?     @relation(fields: [assignedTechId], references: [id], onDelete: SetNull)
  resolvedBy   User?                 @relation("RepairTicketResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  closedBy     User?                 @relation("RepairTicketCloser", fields: [closedById], references: [id], onDelete: SetNull)
  photos       RepairPhoto[]
  parts        RepairPart[]
  events       RepairTimelineEvent[]

  @@index([orgId, status, urgency, createdAt(sort: Desc)])
  @@index([orgId, branchId, status])
  @@index([orgId, assignedTechId, status])
  @@index([orgId, categoryId])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([reporterPhone])
  @@map("repair_tickets")
  @@schema("public")
}

model RepairPhoto {
  id             String           @id @default(uuid()) @db.Uuid
  orgId          String           @map("org_id") @db.Uuid
  ticketId       String           @map("ticket_id") @db.Uuid
  phase          RepairPhotoPhase
  r2Key          String           @map("r2_key")
  r2PublicUrl    String           @map("r2_public_url")
  contentType    String           @default("image/webp") @map("content_type")
  sizeBytes      Int              @default(0) @map("size_bytes")
  width          Int?
  height         Int?
  caption        String?
  uploadedById   String?          @map("uploaded_by_id") @db.Uuid
  uploadedByName String?          @map("uploaded_by_name")
  expiresAt      DateTime?        @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ticket     RepairTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User?        @relation("RepairPhotoUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([ticketId, phase, createdAt])
  @@index([orgId, expiresAt])
  @@map("repair_photos")
  @@schema("public")
}

model RepairPart {
  id             String           @id @default(uuid()) @db.Uuid
  orgId          String           @map("org_id") @db.Uuid
  ticketId       String           @map("ticket_id") @db.Uuid
  name           String
  spec           String?
  quantity       Int              @default(1)
  unit           String           @default("ชิ้น")
  unitPriceCents Int              @default(0) @map("unit_price_cents")
  status         RepairPartStatus @default(NEEDED)
  supplier       String?
  receiptR2Key   String?          @map("receipt_r2_key")
  notes          String?
  addedById      String           @map("added_by_id") @db.Uuid
  orderedAt      DateTime?        @map("ordered_at") @db.Timestamptz(6)
  orderedById    String?          @map("ordered_by_id") @db.Uuid
  deliveredAt    DateTime?        @map("delivered_at") @db.Timestamptz(6)
  installedAt    DateTime?        @map("installed_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ticket    RepairTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  addedBy   User         @relation("RepairPartAddedBy", fields: [addedById], references: [id], onDelete: Restrict)
  orderedBy User?        @relation("RepairPartOrderedBy", fields: [orderedById], references: [id], onDelete: SetNull)

  @@index([orgId, status])
  @@index([ticketId])
  @@index([orgId, name])
  @@map("repair_parts")
  @@schema("public")
}

model RepairTimelineEvent {
  id          String          @id @default(uuid()) @db.Uuid
  orgId       String          @map("org_id") @db.Uuid
  ticketId    String          @map("ticket_id") @db.Uuid
  kind        RepairEventKind
  actorUserId String?         @map("actor_user_id") @db.Uuid
  actorName   String          @map("actor_name")
  payload     Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ticket RepairTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?        @relation("RepairTimelineActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([orgId, createdAt])
  @@map("repair_timeline_events")
  @@schema("public")
}

model RepairVendorToken {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  technicianId String    @map("technician_id") @db.Uuid
  token        String    @unique
  issuedAt     DateTime  @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  usageCount   Int       @default(0) @map("usage_count")

  org        Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  technician RepairTechnician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([orgId, technicianId])
  @@index([token])
  @@index([expiresAt])
  @@map("repair_vendor_tokens")
  @@schema("public")
}

