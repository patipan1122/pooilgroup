// =============================================================
// Timestamped POS event ingestion (Plan B) — per-second cash/coin events
// from StarThing portal. Unlocks per-maid-collection noon-window reconcile.
// Row-level dedup via rowHash unique index (CEO #1 requirement: re-uploading
// overlapping date ranges must NOT double-count). See `[[chairops-pos-events]]`.
// =============================================================

model ChairopsPosCashEvent {
  id             String   @id @default(cuid())
  orgId          String
  branchId       String? // resolved from storeName; null if unmatched
  chairDeviceId  String // รหัสอุปกรณ์
  chairNumber    String? // หมายเลขเครื่องจักร
  storeName      String // raw, for re-resolve/audit
  eventAt        DateTime @db.Timestamptz(6) // เวลา
  cashAdded      Decimal  @db.Decimal(12, 2) // การเพิ่มเงินสด
  cashMeter      Decimal  @db.Decimal(12, 2) // เงินสดทั้งหมด (cumulative)
  rowHash        String // sha256(device|eventAtISO|cashAdded|cashMeter)
  sourceImportId String?
  createdAt      DateTime @default(now())

  branch       ChairopsBranch?    @relation(fields: [branchId], references: [id])
  sourceImport ChairopsPosImport? @relation(fields: [sourceImportId], references: [id])

  @@unique([orgId, rowHash])
  @@index([orgId, branchId, eventAt])
  @@index([orgId, eventAt])
  @@map("chairops_pos_cash_event")
  @@schema("chairops")
}

model ChairopsPosCoinEvent {
  id             String   @id @default(cuid())
  orgId          String
  branchId       String? // resolved from storeName; null if unmatched
  chairDeviceId  String // รหัสอุปกรณ์
  chairNumber    String? // หมายเลขเครื่องจักร
  storeName      String // raw, for re-resolve/audit
  eventAt        DateTime @db.Timestamptz(6) // เวลา
  // 2026-06-01: bumped Int → BigInt · StarThing exports unsigned 32-bit
  // counters and at least one chair already exceeded int4 max (saw value
  // 4_293_916_823). Postgres BIGINT covers up to 9.2e18 · room to spare.
  coinAdded      BigInt // การเพิ่มเหรียญ
  coinMeter      BigInt // จำนวนเหรียญทั้งหมด (cumulative)
  rowHash        String // sha256(device|eventAtISO|coinAdded|coinMeter)
  sourceImportId String?
  createdAt      DateTime @default(now())

  branch       ChairopsBranch?    @relation(fields: [branchId], references: [id])
  sourceImport ChairopsPosImport? @relation(fields: [sourceImportId], references: [id])

  @@unique([orgId, rowHash])
  @@index([orgId, branchId, eventAt])
  @@index([orgId, eventAt])
  @@map("chairops_pos_coin_event")
  @@schema("chairops")
}

// Required by `lib/chairops/auth/session.ts:79-100` denial path (SPEC §2.4)
// Loose FK to Pool users — just store the id (cross-schema).
model ChairopsAccessRequest {
  id         String    @id @default(cuid())
  orgId      String
  poolUserId String
  email      String
  name       String?
  reason     String?
  status     String    @default("PENDING") // PENDING / APPROVED / DENIED
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([orgId])
  @@index([status])
  @@map("chairops_access_request")
  @@schema("chairops")
}

