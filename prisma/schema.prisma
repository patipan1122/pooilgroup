  @@schema("chairops")
}

// =============================================================
// ChairOps Wave 0 additions (per BIGFEATURE_chairops_SPEC §2.2)
// =============================================================

// Per-branch-per-day aggregate (computed from XLSX import)
// See [[chairops-upload-flow-simple-2026-05-27]]
model ChairopsBranchDailyRevenue {
  id              String   @id @default(cuid())
  orgId           String
  branchId        String
  bizDate         DateTime @db.Date
  cashTotal       Decimal  @db.Decimal(12, 2)
  onlineTotal     Decimal  @db.Decimal(12, 2)
  otherTotal      Decimal  @default(0) @db.Decimal(12, 2)
