# Pooilgroup ERP — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local

# ============================================================
# Database (Supabase Postgres)
# ============================================================
# Pooler URL (port 6543) — for runtime queries (recommended for serverless)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# Direct URL (port 5432) — for prisma migrate (bypass pgbouncer)
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ============================================================
# Supabase (auth + types)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxx

# ============================================================
# Cloudflare R2 (file storage)
# ============================================================
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=pooilgroup
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ============================================================
# LINE — shared LIFF login door (whole app)
# ============================================================
NEXT_PUBLIC_LIFF_ID=1234567890-abcdefgh
# Channel SECRET of the LINE Login channel that owns NEXT_PUBLIC_LIFF_ID
# (channelId = the prefix before "-" in NEXT_PUBLIC_LIFF_ID). Used by the
# direct OAuth fallback at /auth/line-callback when LIFF SDK fails to init
# (iOS WKWebView "TypeError: Load failed"). Different from
# CHAIROPS_LINE_CHANNEL_SECRET (Messaging API channel).
CHAIROPS_LINE_LOGIN_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# ChairOps LINE OA (เก้าอี้นวด) — namespaced so other modules' LINE
# configs never collide. Each module owns its own CHAIROPS_/PLAYLAND_/...
# prefix; multi-channel modules (Recruit) store tokens per-channel in DB.
# ============================================================
CHAIROPS_LINE_CHANNEL_ACCESS_TOKEN=xxxxx
CHAIROPS_LINE_CHANNEL_SECRET=xxxxx
# Group IDs — paste from the webhook JOIN log after inviting the OA into each
# group (lib/chairops/line/messaging.ts). Until set, alerts fall back to legacy
# LINE Notify (LINE_NOTIFY_TOKEN_*).
CHAIROPS_LINE_GROUP_FINANCE=
CHAIROPS_LINE_GROUP_REPAIR=
CHAIROPS_LINE_GROUP_OPS=
CHAIROPS_LINE_GROUP_BRANCH=
CHAIROPS_LINE_GROUP_CEO=

# ============================================================
# Telegram Bot
# ============================================================
TELEGRAM_BOT_TOKEN=1234567890:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_WEBHOOK_SECRET=random_string_64_chars
TELEGRAM_ADMIN_CHAT_ID=-1001234567890

# ============================================================
# App config
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3100
NEXT_PUBLIC_APP_TIMEZONE=Asia/Bangkok
JWT_SECRET=generate_with_openssl_rand_hex_32
CRON_SECRET=generate_with_openssl_rand_hex_32

# ============================================================
# AI Chat (เลือกแค่ 1 ตัว — ใส่ตัวไหนก็ได้)
# ============================================================
# Gemini (ฟรี — ขอที่ https://aistudio.google.com/apikey)
# Free tier: gemini-2.5-flash 1500 req/day
GEMINI_API_KEY=

# Claude (เสียเงิน — ขอที่ https://console.anthropic.com)
# ใส่ตัวนี้ถ้าอยากใช้ Claude Haiku แทน Gemini
# ANTHROPIC_API_KEY=

# ============================================================
# Sentry (error tracking)
# ============================================================
# ขอ DSN ที่ https://sentry.io → New Project → Next.js → Pooilgroup
# Vercel project Settings → Environment Variables ใส่ทั้ง 4 ตัวด้านล่าง
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload (เฉพาะ build บน Vercel · ขอ token ที่ sentry.io → Auth Tokens)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ============================================================
# Optional (Phase 2)
# ============================================================
# RESEND_API_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# ⚠️ DEV-ONLY — DO NOT SET IN PRODUCTION
# ============================================================
# NODE_TLS_REJECT_UNAUTHORIZED=0 — disables TLS cert verification
# Required only for local dev where Supabase pooler cert chain
# is seen as self-signed by Node. ห้าม! commit/deploy ตัวนี้
# Production fix: ใช้ Supabase managed pool หรือโหลด CA bundle
# (ดู DEPLOY_READINESS.md)
